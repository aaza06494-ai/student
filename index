async function persistAccountData(){
  if(!currentAccount) return;
  const accountId = currentAccount.id;
  try{
    const { data: existing, error: existingError } = await supabaseClient.from('trades').select('id').eq('account_id', accountId);
    if(existingError) throw existingError;
    const existingIds = (existing||[]).map(t=>t.id).filter(Boolean);
    const currentIds = trades.filter(t=>t.id).map(t=>t.id).filter(Boolean);
    const removedIds = existingIds.filter(id => !currentIds.includes(id));
    if(removedIds.length){
      await supabaseClient.from('trades').delete().in('id', removedIds);
    }
    const tradeRows = trades.map(t => {
      const normalized = normalizeTrade(t);
      const row = {
        account_id: accountId,
        date: normalized.date,
        time: normalized.time,
        asset: normalized.asset,
        market: normalized.market,
        direction: normalized.dir,
        entry: normalized.entry,
        exit: normalized.exit,
        pnl: normalized.pnl,
        sl: normalized.sl,
        tp: normalized.tp,
        result: normalized.result,
        quality: normalized.quality,
        strategy: normalized.strategy,
        sessionTag: normalized.sessionTag,
        notes: normalized.notes,
        created_at: normalized.created_at,
        updated_at: normalized._localUpdatedAt || normalized.updated_at || normalized.created_at
      };
      if(normalized.id) row.id = normalized.id;
      return row;
    });
    await supabaseClient.from('trades').upsert(tradeRows, { onConflict:'id' });
    saveLocalTrades(accountId);
    clearLocalDeletedTradeIds(accountId);
  }catch(e){
    console.warn('Could not save trades to Supabase', e);
    saveLocalTrades(accountId);
  }
  try{
    await supabaseClient.from('accounts').update({ checklists }).eq('id', accountId);
    saveLocalChecks(accountId);
  }catch(e){
    console.warn('Could not save checklists to Supabase', e);
    saveLocalChecks(accountId);
  }
}

