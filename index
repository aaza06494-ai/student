  if(!firstName){ document.getElementById('register-first-name').focus(); return; }
  if(!lastName){ document.getElementById('register-last-name').focus(); return; }
  if(!username){ document.getElementById('login-username').focus(); return; }
  if(!password){ document.getElementById('login-password').focus(); return; }

  const normalized = normalizeUsername(username);
  const authEmail = getAuthEmail(username);
  try{
    const { data: existing, error: existingError } = await supabaseClient.from('users').select('id').eq('username', normalized).single();
    if(existing && existing.id){ tvAlert('Username is already taken. Choose another.','error'); return; }
    if(existingError && existingError.code !== 'PGRST116') throw existingError;

