// Build calendar grid with daily P&L summaries
function renderCalendar(){
  const months=['January','February','March','April','May','June','July','August','September','October','November','December'];
  document.getElementById('cal-month-label').textContent = months[calMonth]+' '+calYear;
  const byDay = {};
  trades.forEach(t=>{
    if(!t.date) return;
    const [y,m,d]=t.date.split('-').map(Number);
    if(y===calYear&&m-1===calMonth){
      if(!byDay[d]) byDay[d]={pnl:0,count:0};
      byDay[d].pnl+=(parseFloat(t.pnl)||0);
      byDay[d].count++;
    }
  });
  const first = new Date(calYear,calMonth,1).getDay();
  const days = new Date(calYear,calMonth+1,0).getDate();
  const today = new Date();
  let html='';
  for(let i=0;i<first;i++) html+='<div class="cal-day empty"></div>';
  for(let d=1;d<=days;d++){
    const info=byDay[d];
    const isToday=(today.getFullYear()===calYear&&today.getMonth()===calMonth&&today.getDate()===d);
    let cls='cal-day';
    if(isToday) cls+=' today';
    if(info){cls+=info.pnl>=0?' profit':' loss';}
    const pnlTxt=info?(info.pnl>=0?'+':'')+' $'+Math.abs(info.pnl).toFixed(2):'';
    const tradesTxt=info?`${info.count} trade${info.count>1?'s':''}` :'';
    html+=`<div class="${cls}" onclick="${info?`openDayModal(${d})`:''}">
      <div class="cal-day-num">${d}</div>
      ${info?`<div class="cal-day-pnl">${pnlTxt}</div><div class="cal-day-trades">${tradesTxt}</div>`:''}
    </div>`;
  }
  document.getElementById('cal-body').innerHTML=html;

  // Monthly P&L box
  const monthlyPnl = Object.values(byDay).reduce((a,b)=>a+b.pnl, 0);
  const pnlBox = document.getElementById('cal-month-pnl');
  if(pnlBox){
    const pos = monthlyPnl >= 0;
    const fmt = '$'+Math.abs(monthlyPnl).toLocaleString('en',{minimumFractionDigits:2,maximumFractionDigits:2});
    pnlBox.textContent = (pos ? '+ ' : '− ') + fmt;
    pnlBox.style.background = pos ? 'rgba(0,242,255,0.12)' : 'rgba(255,71,87,0.12)';
    pnlBox.style.border = pos ? '1px solid rgba(0,242,255,0.35)' : '1px solid rgba(255,71,87,0.35)';
    pnlBox.style.color = pos ? 'var(--green)' : 'var(--red)';
    pnlBox.style.display = Object.keys(byDay).length ? 'block' : 'none';
  }
}
