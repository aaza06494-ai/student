<style>
:root{
  --bg:#050508;
  --bg2:#0a0a0f;
  --bg3:#11111a;
  --bg4:#18181f;
  --border:rgba(255,255,255,0.08);
  --border2:rgba(255,255,255,0.14);
  --green:#00f2ff;
  --green2:#00d4e0;
  --green-dim:rgba(0,242,255,0.10);
  --green-dim2:rgba(0,242,255,0.05);
  --red:#ff4757;
  --red-dim:rgba(255,71,87,0.12);
  --text:#f0f0f5;
  --text2:#9898a8;
  --text3:#55555f;
  --amber:#ffd700;
  --blue:#00f2ff;
  --font-head:'Syne',sans-serif;
  --font-mono:'DM Mono',monospace;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;background:var(--bg) url('https://images.unsplash.com/photo-1639762681485-074b7f938ba0?q=80&w=2070') no-repeat center center fixed;background-size:cover;color:var(--text);font-family:var(--font-mono);font-size:14px;overflow:hidden}
::selection{background:var(--green-dim);color:var(--green)}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:var(--bg2)}
::-webkit-scrollbar-thumb{background:rgba(0,242,255,0.3);border-radius:2px}

/* ===== CUSTOM CONFIRM MODAL ===== */
#tv-confirm-overlay{position:fixed;inset:0;z-index:99999;background:rgba(5,5,8,0.82);backdrop-filter:blur(12px);display:none;align-items:center;justify-content:center;}
#tv-confirm-overlay.active{display:flex;animation:tvFadeIn .18s ease;}
@keyframes tvFadeIn{from{opacity:0}to{opacity:1}}
#tv-confirm-box{background:var(--bg2);border:1px solid rgba(0,242,255,0.22);border-radius:18px;padding:32px 28px 24px;width:min(420px,92vw);box-shadow:0 0 60px rgba(0,242,255,0.10),0 24px 48px rgba(0,0,0,0.6);animation:tvSlideUp .2s cubic-bezier(.22,1,.36,1);text-align:center;}
@keyframes tvSlideUp{from{transform:translateY(18px);opacity:0}to{transform:none;opacity:1}}
#tv-confirm-icon{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:26px;margin:0 auto 16px;}
#tv-confirm-icon.danger{background:rgba(255,71,87,0.14);border:1px solid rgba(255,71,87,0.3);}
#tv-confirm-icon.warn{background:rgba(255,215,0,0.12);border:1px solid rgba(255,215,0,0.28);}
#tv-confirm-icon.info{background:rgba(0,242,255,0.10);border:1px solid rgba(0,242,255,0.25);}
#tv-confirm-title{font-family:var(--font-head);font-size:17px;font-weight:800;color:var(--text);margin-bottom:8px;line-height:1.3;}
#tv-confirm-msg{color:var(--text2);font-size:13px;line-height:1.6;margin-bottom:24px;}
#tv-confirm-actions{display:flex;gap:10px;justify-content:center;}
#tv-confirm-ok{flex:1;padding:12px 0;border:none;border-radius:10px;font-family:var(--font-head);font-size:14px;font-weight:700;cursor:pointer;transition:filter .15s;}
#tv-confirm-ok.danger{background:var(--red);color:#fff;}
#tv-confirm-ok.warn{background:var(--amber);color:#000;}
#tv-confirm-ok.info{background:var(--green);color:#000;}
#tv-confirm-ok:hover{filter:brightness(1.12);}
#tv-confirm-cancel{flex:1;padding:12px 0;border:1px solid var(--border2);border-radius:10px;background:var(--bg3);color:var(--text2);font-family:var(--font-head);font-size:14px;font-weight:600;cursor:pointer;transition:background .15s;}
#tv-confirm-cancel:hover{background:var(--bg4);}

/* LOGIN SCREEN */
.login-screen{position:fixed;inset:0;background:rgba(5,5,10,0.88);backdrop-filter:blur(24px);display:none;align-items:center;justify-content:center;z-index:9999}
.login-box{background:var(--bg2);border:1px solid rgba(0,242,255,0.25);border-radius:18px;padding:36px 40px;width:auto;min-width:300px;max-width:360px;text-align:center;box-shadow:0 0 60px rgba(0,242,255,0.08)}
.login-logo{font-family:var(--font-head);font-size:22px;font-weight:800;color:var(--amber);letter-spacing:.04em;margin-bottom:6px}
.login-logo span{color:var(--green)}
.login-sub{color:var(--text3);font-size:13px;margin-bottom:28px}
.login-input{background:var(--bg3);border:1px solid var(--border2);color:#fff;padding:12px 14px;border-radius:8px;width:100%;outline:none;font-family:var(--font-mono);font-size:14px;transition:border .15s;margin-bottom:16px}
.login-input:focus{border-color:var(--green)}
.login-input::placeholder{color:var(--text3)}
.login-btn{background:var(--green);color:#000;padding:12px 0;width:100%;border:none;border-radius:8px;font-weight:700;font-size:14px;cursor:pointer;font-family:var(--font-head);letter-spacing:.04em;transition:background .15s}
.login-btn:hover{background:var(--green2)}

/* LAYOUT */
.shell{display:flex;height:100vh;background:rgba(5,5,8,0.88);position:relative;isolation:isolate;}.shell::before{content:"";position:fixed;inset:0;backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);z-index:-1;pointer-events:none;}
.sidebar{width:220px;min-width:220px;background:rgba(0,0,0,0.45);border-right:1px solid var(--border);display:flex;flex-direction:column;padding:0}
.sb-logo{padding:20px 20px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px}
.sb-logo-icon{width:32px;height:32px;background:var(--green);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.sb-logo-icon svg{width:18px;height:18px;fill:none;stroke:#000;stroke-width:2.5}
.sb-logo-text{font-family:var(--font-head);font-weight:800;font-size:16px;letter-spacing:-.02em;color:var(--text)}
.sb-logo-text span{color:var(--green)}
.sb-nav{flex:1;padding:12px 8px;overflow-y:auto}
.sb-section{font-size:10px;font-weight:500;color:var(--text3);letter-spacing:.1em;text-transform:uppercase;padding:8px 12px 4px;margin-top:4px}
.nav-item{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:8px;cursor:pointer;color:var(--text2);font-size:13px;transition:all .15s;margin-bottom:2px;border:none;background:none;width:100%;text-align:left;font-family:var(--font-mono)}
.nav-item:hover{background:var(--bg3);color:var(--text)}
.nav-item.active{background:rgba(0,242,255,0.08);color:var(--green);border-left:3px solid var(--green)}
.nav-item svg{width:16px;height:16px;flex-shrink:0;opacity:.7}
.nav-item.active svg{opacity:1}
.sb-footer{padding:12px 8px;border-top:1px solid var(--border)}
.sb-account{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:8px;background:var(--bg3);cursor:pointer}
.sb-avatar{width:30px;height:30px;border-radius:50%;background:var(--green-dim);border:1.5px solid var(--green);display:flex;align-items:center;justify-content:center;font-size:12px;color:var(--green);font-weight:500;flex-shrink:0}
.sb-account-info{flex:1;min-width:0}
.sb-account-name{font-size:13px;color:var(--text);font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.sb-account-badge{font-size:10px;color:var(--green);margin-top:1px}

.main{flex:1;display:flex;flex-direction:column;overflow:hidden}
.topbar{height:52px;border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 24px;gap:16px;background:rgba(0,0,0,0.35);flex-shrink:0}
.topbar-title{font-family:var(--font-head);font-weight:700;font-size:18px;flex:1}
.topbar-chip{background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:4px 10px;font-size:12px;color:var(--text2);display:flex;align-items:center;gap:6px}
.topbar-chip .dot{width:6px;height:6px;border-radius:50%;background:var(--green);box-shadow:0 0 8px var(--green)}
.btn{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:7px;font-size:13px;cursor:pointer;border:none;font-family:var(--font-mono);transition:all .15s}
.btn-green{background:var(--green);color:#000;font-weight:500}
.btn-green:hover{background:var(--green2)}.btn-outline{background:transparent;color:var(--text2);border:1px solid var(--border2)}
.btn-outline:hover{border-color:var(--green);color:var(--green)}
.btn-sm{padding:5px 10px;font-size:12px}
.btn-danger{background:var(--red-dim);color:var(--red);border:1px solid rgba(255,71,87,.2)}

.content{flex:1;overflow-y:auto;padding:24px}

/* PAGES */
.page{display:none}.page.active{display:block}

/* STAT CARDS */
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px}
.stat-card{background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:16px 18px;position:relative;overflow:hidden}
.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--c,var(--green)),transparent);opacity:.8}
.stat-card-label{font-size:11px;color:var(--text3);letter-spacing:.06em;text-transform:uppercase;margin-bottom:8px}
.stat-card-value{font-family:var(--font-head);font-size:24px;font-weight:700;color:var(--text);line-height:1}
.stat-card-value.pos{color:var(--green)}
.stat-card-value.neg{color:var(--red)}
.stat-card-sub{font-size:11px;color:var(--text3);margin-top:6px}
.stat-card-icon{position:absolute;right:16px;top:16px;width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;background:var(--bg3)}
.stat-card-icon svg{width:16px;height:16px}

/* CHART AREA */
.chart-card{background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:20px;margin-bottom:20px}
.chart-card-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.chart-card-title{font-family:var(--font-head);font-size:15px;font-weight:600}
.chart-wrap{position:relative;height:200px}

/* CALENDAR */
.cal-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.cal-month{font-family:var(--font-head);font-size:20px;font-weight:700}
.cal-nav{display:flex;gap:6px}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:6px}
.cal-day-header{text-align:center;font-size:11px;color:var(--text3);padding:6px 0;letter-spacing:.06em}
.cal-day{background:var(--bg3);border:1px solid var(--border);border-radius:10px;min-height:72px;padding:8px;cursor:pointer;transition:all .15s;position:relative}
.cal-day:hover{border-color:var(--border2);background:var(--bg4)}
.cal-day.empty{background:transparent;border-color:transparent;cursor:default}
.cal-day.today{border-color:var(--green);box-shadow:0 0 0 1px var(--green-dim)}
.cal-day.profit{background:rgba(0,229,160,.08);border-color:rgba(0,229,160,.3)}
.cal-day.loss{background:rgba(255,71,87,.08);border-color:rgba(255,71,87,.3)}
.cal-day-num{font-size:11px;color:var(--text3);margin-bottom:4px}
.cal-day-pnl{font-size:13px;font-weight:600;font-family:var(--font-head)}
.cal-day.profit .cal-day-pnl{color:var(--green)}
.cal-day.loss .cal-day-pnl{color:var(--red)}
.cal-day-trades{font-size:10px;color:var(--text3);margin-top:2px}

/* TABLE */
.table-wrap{background:var(--bg2);border:1px solid var(--border);border-radius:12px;overflow:hidden}
.table-header{display:flex;align-items:center;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--border)}
.data-table{width:100%;border-collapse:collapse}
.data-table th{padding:10px 14px;text-align:left;font-size:10px;color:var(--amber);letter-spacing:.08em;text-transform:uppercase;border-bottom:1px solid var(--border);white-space:nowrap;background:var(--bg3)}
.data-table td{padding:11px 14px;font-size:13px;border-bottom:1px solid rgba(42,42,50,.5);white-space:nowrap}
.data-table tr:last-child td{border-bottom:none}
.data-table tbody tr{cursor:pointer;transition:background .1s}
.data-table tbody tr:hover{background:var(--bg3)}
.badge{display:inline-flex;align-items:center;padding:3px 8px;border-radius:4px;font-size:11px;font-weight:500}
.badge-win{background:rgba(0,229,160,.15);color:var(--green)}
.badge-loss{background:rgba(255,71,87,.15);color:var(--red)}
.badge-be{background:rgba(255,181,71,.15);color:var(--amber)}
.badge-buy{background:rgba(77,159,255,.15);color:var(--blue)}
.badge-sell{background:rgba(255,71,87,.15);color:var(--red)}
.tag{display:inline-flex;align-items:center;padding:2px 7px;border-radius:4px;font-size:10px;background:var(--bg4);color:var(--text2);border:1px solid var(--border);margin:1px}

/* MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);backdrop-filter:blur(4px);z-index:100;display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;pointer-events:none;transition:opacity .2s}
.modal-overlay.open{opacity:1;pointer-events:all}
.modal{background:var(--bg2);border:1px solid var(--border2);border-radius:16px;width:100%;max-width:720px;max-height:90vh;overflow-y:auto;padding:24px;position:relative}
.modal-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px}
.modal-title{font-family:var(--font-head);font-size:18px;font-weight:700}
.modal-close{background:var(--bg3);border:1px solid var(--border);border-radius:6px;width:30px;height:30px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--text2);font-size:18px}
.modal-close:hover{border-color:var(--red);color:var(--red)}
.modal-close svg{width:16px;height:16px}

/* FORM */
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.form-grid.cols3{grid-template-columns:1fr 1fr 1fr}
.form-grid.full{grid-template-columns:1fr}
.form-group{display:flex;flex-direction:column;gap:5px}
.form-group.span2{grid-column:span 2}
label.form-label{font-size:11px;color:var(--text3);letter-spacing:.05em;text-transform:uppercase}
input.form-input,select.form-input,textarea.form-input{background:var(--bg3);border:1px solid var(--border);border-radius:7px;padding:8px 11px;color:var(--text);font-family:var(--font-mono);font-size:13px;width:100%;outline:none;transition:border .15s;resize:none}
input.form-input:focus,select.form-input:focus,textarea.form-input:focus{border-color:var(--green)}
input.form-input::placeholder,textarea.form-input::placeholder{color:var(--text3)}
select.form-input option{background:var(--bg3)}
.form-section{margin-bottom:18px}
.form-section-title{font-family:var(--font-head);font-size:13px;font-weight:600;color:var(--text2);margin-bottom:10px;padding-bottom:6px;border-bottom:1px solid var(--border)}

/* CHECKLIST */
.checklist-item{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:8px;background:var(--bg3);margin-bottom:6px;cursor:pointer;transition:all .15s}
.checklist-item:hover{background:var(--bg4)}
.checklist-item.checked{background:var(--green-dim2)}
.checklist-check{width:18px;height:18px;border:1.5px solid var(--border2);border-radius:4px;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .15s}
.checklist-item.checked .checklist-check{background:var(--green);border-color:var(--green)}
.check-tick{width:10px;height:10px;fill:none;stroke:#000;stroke-width:2.5;stroke-linecap:round;stroke-linejoin:round;display:none}
.checklist-item.checked .check-tick{display:block}
.checklist-text{font-size:13px;flex:1}
.checklist-item.checked .checklist-text{text-decoration:line-through;color:var(--text3)}
.checklist-badge{font-size:10px;padding:2px 7px;border-radius:3px;background:var(--bg4);color:var(--text3)}
.checklist-badge.req{background:rgba(255,71,87,.1);color:var(--red)}
.checklist-screenshot-row{margin:8px 0 0 34px;display:flex;gap:8px;flex-wrap:wrap}
.checklist-screenshot-row img{width:80px;height:56px;object-fit:cover;border-radius:8px;border:1px solid var(--border);cursor:pointer}
.checklist-screenshot-row img:hover{border-color:var(--green)}

/* ANALYSIS FIELDS */
.analysis-field{background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:14px;margin-bottom:10px}
.analysis-field-label{font-size:10px;color:var(--text3);letter-spacing:.08em;text-transform:uppercase;margin-bottom:8px}
.analysis-field-content{font-size:13px;color:var(--text);line-height:1.6}

/* TAG FILTERS */
.tag-filters{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px}
.tag-filter{padding:5px 12px;border-radius:6px;font-size:12px;cursor:pointer;border:1px solid var(--border);background:var(--bg3);color:var(--text2);transition:all .15s}
.tag-filter.active{border-color:var(--green);background:var(--green-dim);color:var(--green)}

/* STATS PAGE */
.stats-row{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px}
.stats-section{background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:20px}
.stats-section-title{font-family:var(--font-head);font-size:14px;font-weight:600;margin-bottom:14px;color:var(--text2)}
.stats-item{display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgba(42,42,50,.5)}
.stats-item:last-child{border-bottom:none}
.stats-item-label{font-size:13px;color:var(--text2)}
.stats-item-value{font-size:13px;font-weight:500;font-family:var(--font-head)}

/* SCREENSHOT */
.screenshot-zone{border:1.5px dashed var(--border2);border-radius:10px;padding:24px;text-align:center;cursor:pointer;transition:all .15s}
.screenshot-zone:hover{border-color:var(--green);background:var(--green-dim2)}
.screenshot-gallery{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-top:12px}
.screenshot-thumb{aspect-ratio:16/9;background:var(--bg3);border-radius:8px;border:1px solid var(--border);overflow:hidden;position:relative;cursor:pointer}
.screenshot-thumb img{width:100%;height:100%;object-fit:cover}
.screenshot-thumb-label{position:absolute;bottom:6px;left:6px;background:rgba(0,0,0,.7);padding:2px 7px;border-radius:4px;font-size:10px;color:var(--text2)}

/* AI PANEL */
.ai-score{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin:16px 0}
.ai-score-item{background:var(--bg3);border-radius:10px;padding:14px;text-align:center}
.ai-score-num{font-family:var(--font-head);font-size:28px;font-weight:700;margin-bottom:4px}
.ai-score-label{font-size:11px;color:var(--text3)}
.ai-response{background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:16px;font-size:13px;line-height:1.7;color:var(--text2);max-height:300px;overflow-y:auto}
.ai-response .bullet{color:var(--green);margin-right:6px}
.ai-loading{display:flex;align-items:center;gap:8px;color:var(--text3);font-size:13px}
.ai-dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse 1.2s ease-in-out infinite}
.ai-dot:nth-child(2){animation-delay:.2s}
.ai-dot:nth-child(3){animation-delay:.4s}
