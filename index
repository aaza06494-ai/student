async function convDoImport(){
  if(!convParsedTrades.length){ tvAlert('Nothing to import!','warn'); return; }
  if(!await ensureImportAccountLoaded()) return;
  const maxId = trades.length?Math.max(...trades.map(t=>t.id||0)):0;
  let nextId = maxId+1, imported=0;
  convParsedTrades.forEach(t=>{
    const dup = trades.find(x=>x.asset===t.asset&&x.date===t.date&&Math.abs(safeNumber(x.pnl)-safeNumber(t.pnl))<0.01);
    if(dup) return;
    trades.push(normalizeTrade({...t, id: nextId++, _localUpdatedAt: new Date().toISOString(), created_at: new Date().toISOString(), updated_at: new Date().toISOString()}));
    imported++;
  });
  save(); renderDashboard(); renderCalendar(); renderJournal();
  _showToast(imported>0?`✅ ${imported} trades imported successfully`:'⚠ All trades already exist (duplicates skipped)', imported>0?'#00f2ff':'#ffd700');
  if(imported>0){
    document.getElementById('conv-input').value='';
    document.getElementById('conv-output').innerHTML='<div style="color:var(--green);text-align:center;padding:20px">✅ '+imported+' trades imported!</div>';
    document.getElementById('conv-import-bar').style.display='none';
    convParsedTrades=[];
  }
}

