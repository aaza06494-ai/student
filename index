// Auto-calculate SL/TP, RR and P&L for the trade modal
function autoCalcTrade(){
  const entry = parseFloat(document.getElementById('t-entry').value);
  const sl    = parseFloat(document.getElementById('t-sl').value);
  const tp    = parseFloat(document.getElementById('t-tp').value);
  const exit  = parseFloat(document.getElementById('t-exit').value);
  const dir   = document.getElementById('t-dir')?.value || 'Buy';

  // Get point value based on mode
  let pointVal = 0;
  if(tradeMode === 'lot'){
    const qty = parseFloat(document.getElementById('t-lot-qty')?.value) || 1;
    pointVal = qty * 20;
    const hint = document.getElementById('t-lot-hint');
    if(hint) hint.textContent = qty+' standard lot'+(qty!==1?'s':'')+' = $'+pointVal.toFixed(2)+' per point on NAS100';
  } else {
    const qty = parseFloat(document.getElementById('t-fut-qty')?.value) || 1;
    pointVal = qty * TRADE_FUTURES[tradeFuturesType].val;
  }

  if(!entry || !sl || !tp) return;

  // SL/TP direction validation
  const slWarnEl = document.getElementById('t-sltp-warn');
  let warnMsg = '';
  if(dir === 'Buy'){
    if(sl >= entry) warnMsg = '⚠ Buy trade: SL should be BELOW entry price';
    else if(tp <= entry) warnMsg = '⚠ Buy trade: TP should be ABOVE entry price';
  } else {
    if(sl <= entry) warnMsg = '⚠ Sell trade: SL should be ABOVE entry price';
    else if(tp >= entry) warnMsg = '⚠ Sell trade: TP should be BELOW entry price';
  }
  if(slWarnEl){ slWarnEl.textContent = warnMsg; slWarnEl.style.display = warnMsg ? 'block' : 'none'; }

  const slPts = Math.abs(entry - sl);
  const tpPts = Math.abs(tp - entry);
  const slDollar = slPts * pointVal;
  const tpDollar = tpPts * pointVal;
  const rr = slDollar > 0 ? tpDollar/slDollar : 0;

  // Update RR ratio field
  document.getElementById('t-rr').value = '1:' + rr.toFixed(2);

  // Show result cards
  const cards = document.getElementById('t-result-cards');
  if(cards) cards.style.display = 'block';

  const slDollarEl = document.getElementById('t-sl-dollar');
  const tpDollarEl = document.getElementById('t-tp-dollar');
  const slPtsEl    = document.getElementById('t-sl-pts');
  const tpPtsEl    = document.getElementById('t-tp-pts');
  const rrDisp     = document.getElementById('t-rr-display');
  const rrDesc     = document.getElementById('t-rr-desc');

  if(slDollarEl) slDollarEl.textContent = '−$'+slDollar.toFixed(2);
  if(tpDollarEl) tpDollarEl.textContent = '+$'+tpDollar.toFixed(2);
  if(slPtsEl)    slPtsEl.textContent = slPts.toFixed(1)+' pts from entry';
  if(tpPtsEl)    tpPtsEl.textContent = tpPts.toFixed(1)+' pts from entry';
  if(rrDisp)     rrDisp.textContent = '1 : '+rr.toFixed(2);
  if(rrDesc)     rrDesc.textContent = 'Risk $'+slDollar.toFixed(2)+' → Target $'+tpDollar.toFixed(2);

  // P&L based on result dropdown or explicit exit price
  const resultEl = document.getElementById('t-result');
  const res = resultEl ? resultEl.value : 'Win';
  let pnl;
  if(exit){
    // Real exit price used
    const exitPts = dir==='Buy' ? exit-entry : entry-exit;
    pnl = exitPts * pointVal;
  } else {
    pnl = res==='Win' ? tpDollar : res==='Loss' ? -slDollar : 0;
  }

  const pnlEl = document.getElementById('t-pnl');
  if(pnlEl) pnlEl.value = (pnl>=0?'+':'')+pnl.toFixed(2);

  // Auto-set result from P&L when exit provided
  if(resultEl && exit){
    if(pnl > 0) resultEl.value = 'Win';
    else if(pnl < 0) resultEl.value = 'Loss';
    else resultEl.value = 'BE';
  }
}
