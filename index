function previewPaste(){
  const text = document.getElementById('paste-area').value.trim();
  const preview = document.getElementById('paste-preview');
  if(!text){ preview.style.display='none'; return; }
  const lines = text.split('\n').filter(l=>l.trim());
  // Detect separator
  const sep = lines[0].includes('\t') ? '\t' : ',';
  const headers = lines[0].split(sep).map(h=>h.replace(/"/g,'').trim().toLowerCase());
  const isKML  = _isKMLCSV(headers);
  const isTVhdr= !isKML && _isTradingViewCSV(headers);
  const isTVml = !isKML && !isTVhdr && _isTVMultiline(text);
  const isTV   = isTVhdr || isTVml;
  const orderCount = lines.filter(l=>_isSide(l.trim())).length;
  const tradeCount = lines.length-1;
  preview.style.display='block';
  preview.innerHTML = isKML
    ? '<div style="background:rgba(0,242,255,0.07);border:1px solid rgba(0,242,255,0.2);border-radius:7px;padding:10px">'+
      '✅ <b style="color:var(--green)">KML / Tradovate format detected</b> — <b>'+tradeCount+'</b> trades found</div>'
    : isTV
    ? '<div style="background:rgba(0,242,255,0.07);border:1px solid rgba(0,242,255,0.2);border-radius:7px;padding:10px">'+
      '✅ <b style="color:var(--green)">TradingView format detected</b>'+(isTVml?' <span style="color:var(--text3);font-size:11px">(multi-line)</span>':'')+' — <b>'+orderCount+'</b> orders found</div>'
    : '<div style="background:rgba(255,181,71,0.07);border:1px solid rgba(255,181,71,0.2);border-radius:7px;padding:10px">'+
      '⚠️ Format not recognized — will try generic import</div>';
}

