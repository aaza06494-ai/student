// ===== IMPORT MT5 CSV / XLSX =====
async function importCSV(input){
  const file = input.files[0];
  if(!file) return;
  if(!await ensureImportAccountLoaded()) return;

  const isXLSX = file.name.match(/\.xlsx?$/i);

  if(isXLSX){
    // load SheetJS dynamically if not already loaded
    if(!window.XLSX){
      const s = document.createElement('script');
      s.src='https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js';
      s.onload=()=>_readXLSX(file, input);
      document.head.appendChild(s);
    } else {
      _readXLSX(file, input);
    }
  } else {
    const reader = new FileReader();
    reader.onload = e => _parseAndImport(e.target.result, input);
    reader.readAsText(file);
  }
}

function _readXLSX(file, input){
  const reader = new FileReader();
  reader.onload = function(e){
    const wb = XLSX.read(e.target.result, {type:'array'});
    const ws = wb.Sheets[wb.SheetNames[0]];
    // get all rows as arrays
    const rows = XLSX.utils.sheet_to_json(ws, {header:1, defval:''});
    _parseXLSXRows(rows, input);
  };
  reader.readAsArrayBuffer(file);
}

function _parseXLSXRows(rows, input){
  // find the header row (contains 'Instrument' or 'Symbol')
  let headerIdx = -1;
  for(let i=0;i<rows.length;i++){
    const r = rows[i].map(c=>String(c).toLowerCase());
    if(r.includes('instrument') || r.includes('symbol') || r.includes('open price')){
      headerIdx = i;
      break;
    }
  }
  if(headerIdx === -1){ 
    _showToast('⚠ Could not find trade data in file', '#ffd700');
    return;
  }

  const headers = rows[headerIdx].map(h=>String(h).toLowerCase().trim());
  let imported = 0;
  const maxId = trades.length ? Math.max(...trades.map(t=>t.id||0)) : 0;
  let nextId = maxId + 1;

  for(let i=headerIdx+1;i<rows.length;i++){
    const cols = rows[i];
    if(!cols || cols.length < 3) continue;

    const row = {};
    headers.forEach((h,idx)=>{ row[h] = cols[idx] !== undefined ? String(cols[idx]).trim() : ''; });

    const symbol = row['instrument'] || row['symbol'] || '';
    if(!symbol || symbol==='' || symbol.toLowerCase()==='total') continue;

    const type = (row['type']||'').toLowerCase();
    if(type==='balance'||type==='deposit'||type==='credit') continue;

    const profit    = parseFloat(row['profit']||0);
    const volume    = parseFloat(row['amount']||row['volume']||row['lots']||0);
    const openPrice = parseFloat(row['open price']||row['price']||0);
    const closePrice= parseFloat(row['close price']||0);
    const openTime  = row['open time']||row['time']||row['date']||'';
    const closeTime = row['close time']||'';
    function normDate(str){
      if(!str) return '';
      const d = str.split(' ')[0];
      if(d.includes('/')){
        const p = d.split('/');
        if(p[0].length===4) return p[0]+'-'+p[1]+'-'+p[2];
        return p[2]+'-'+p[1]+'-'+p[0];
      }
      return d;
    }
    const datePart = normDate(openTime);

    let result = 'BE';
    if(profit > 0) result = 'Win';
    else if(profit < 0) result = 'Loss';

    const dup = trades.find(t=>t.asset===symbol && t.date===datePart && parseFloat(t.pnl)===profit);
    if(dup) continue;

    trades.push({
      id: nextId++,
      date: datePart,
      time: openTime.split(' ')[1]||'',
      asset: symbol,
      market: 'Forex',
      session: 'London',
      dir: type.charAt(0).toUpperCase()+type.slice(1)||'Buy',
      entry: String(openPrice),
      exit: String(closePrice),
      sl: row['s/l']||'',
      tp: row['t/p']||'',
      risk: '',
      rr: '',
      pnl: String(profit),
      result: result,
      quality: '',
      strategy: '#MT5',
      sessionTag: '',
      setup: 'Imported from MT5',
      entryReason: '',
      exitReason: '',
      emotion: '',
      mistakes: '',
      lessons: '',
      _imported: true
    });
    imported++;
  }

  save();
  renderDashboard();
  renderCalendar();
  renderJournal();
  if(input) input.value='';
  _showToast(imported > 0 ? `✅ ${imported} trades imported from MT5` : '⚠ No trades found — check file format', imported>0?'#00f2ff':'#ffd700');
}



