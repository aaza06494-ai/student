function calcPos(){
  const lt=currentLotType;
  const asset=document.getElementById('c-asset').value;
  const contracts=parseFloat(document.getElementById('c-contracts').value)||1;
  const entry=parseFloat(document.getElementById('c-entry').value);
  const sl=parseFloat(document.getElementById('c-sl').value);
  const tp=parseFloat(document.getElementById('c-tp').value);
  const dir=document.getElementById('c-dir').value;
  if(!entry||!sl||!tp) return;
  const pipVal=LOT_DATA[lt].pip[asset]||2;
  const perPip=pipVal*contracts;
  const slPips=Math.abs(entry-sl);
  const tpPips=Math.abs(tp-entry);
  const slTicks=Math.round(slPips*4);
  const tpTicks=Math.round(tpPips*4);
  const slUsd=slPips*perPip;
  const tpUsd=tpPips*perPip;
  const rr=(tpUsd/slUsd).toFixed(2);
  const rrNum=parseFloat(rr);

  document.getElementById('c-results').style.display='block';
  document.getElementById('r-tp').textContent='+$'+tpUsd.toFixed(2);
  document.getElementById('r-sl').textContent='-$'+slUsd.toFixed(2);
  document.getElementById('r-tp-pips').textContent=tpPips.toFixed(1)+' pips · '+tpTicks+' ticks';
  document.getElementById('r-sl-pips').textContent=slPips.toFixed(1)+' pips · '+slTicks+' ticks';
  document.getElementById('r-rr').textContent='1:'+rr;
  document.getElementById('r-rr-lbl').textContent=rrNum>=2?'✅ Excellent RR':rrNum>=1.5?'✅ Good RR':rrNum>=1?'⚠ Acceptable':'❌ Poor RR';
  document.getElementById('r-pip').textContent='$'+perPip.toFixed(2);
  document.getElementById('r-pip-lbl').textContent=LOT_DATA[lt].label+' · '+asset+' · '+contracts+' contract'+(contracts>1?'s':'');
  document.getElementById('r-summary').innerHTML=
    `Type: <b style="color:var(--text)">${LOT_DATA[lt].label}</b> &nbsp;·&nbsp; Contracts: <b style="color:var(--text)">${contracts}</b> &nbsp;·&nbsp; Asset: <b style="color:var(--text)">${asset}</b><br>`+
    `SL Distance: <b style="color:var(--red)">${slPips.toFixed(1)} pips = ${slTicks} ticks = <span style="font-size:15px">$${slUsd.toFixed(2)}</span></b><br>`+
    `TP Distance: <b style="color:var(--green)">${tpPips.toFixed(1)} pips = ${tpTicks} ticks = <span style="font-size:15px">$${tpUsd.toFixed(2)}</span></b><br>`+
    `Value per pip: <b style="color:var(--amber)">$${perPip.toFixed(2)}</b>`;
}
