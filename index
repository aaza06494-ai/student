async function initAuth(){
  initLoginHandlers();
  // Show app instantly if session exists in localStorage — no waiting for Supabase
  const _quickUserId = localStorage.getItem('tv_user_id');
  const _quickUsername = localStorage.getItem('tv_username');
  if(_quickUserId && _quickUsername){
    currentUserId = _quickUserId;
    currentUser = _quickUsername;
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('app-shell').style.display = 'flex';
    const _quickAccountId = localStorage.getItem('tv_account_id');
    if(_quickAccountId){ currentAccountId = _quickAccountId; }
    initApp();
  } else {
    hideAuthScreens();
  }
  if(authStateChangeSubscription){ authStateChangeSubscription.unsubscribe(); authStateChangeSubscription = null; }
  const authStateResult = supabaseClient.auth.onAuthStateChange(async (event, session) => {
    await handleSupabaseAuthStateChange(event, session);
  });
  authStateChangeSubscription = authStateResult?.data?.subscription || authStateResult?.subscription || authStateResult || null;
  if(authStateResult?.error){ console.warn('[auth] onAuthStateChange failed', authStateResult.error); }

  let session = null;
  try{
    const { data, error } = await supabaseClient.auth.getSession();
    if(error){ console.warn('[auth] getSession error', error); }
    session = data?.session || null;
  }catch(err){
    console.warn('[auth] getSession failed', err);
  }

  const storedUserId = localStorage.getItem('tv_user_id');
  const storedUsername = localStorage.getItem('tv_username');
  const storedAccountId = localStorage.getItem('tv_account_id');

  if(session && session.user){
    const restored = await restoreSessionFromSupabase(session);
    if(restored){
      await loadAccountList();
      if(accounts.length){
        const selectId = storedAccountId && accounts.some(a=>a.id===storedAccountId) ? storedAccountId : accounts[0].id;
        await selectAccount(selectId);
      }
      showApp();
      initApp();
      authInitialized = true;
      return;
    }
  }

  if(storedUserId && storedUsername){
    currentUserId = storedUserId;
    currentUser = storedUsername;
    try{
      const { data, error } = await supabaseClient.from('users').select('username').eq('id', currentUserId).single();
      if(!error && data && data.username !== normalizeUsername(currentUser)){
        clearSession();
        showLogin();
        authInitialized = true;
        return;
      }
    }catch(e){
      console.warn('[auth] legacy session restore check failed, continuing anyway', e);
    }
    await loadAccountList();
    if(accounts.length){
      const selectId = storedAccountId && accounts.some(a=>a.id===storedAccountId) ? storedAccountId : accounts[0].id;
      await selectAccount(selectId);
    }
    showApp();
    initApp();
  } else {
    showLogin();
  }

  authInitialized = true;
}

async function migrateLegacyData(){
  if(!currentUserId) return;
  if(localStorage.getItem('legacy_data_migrated_'+currentUserId)) return;
  const legacyNames = [];
  const currentLegacy = localStorage.getItem('theo_user');
  if(currentLegacy) legacyNames.push(currentLegacy);
  const known = JSON.parse(localStorage.getItem('tv_users')||'[]');
  known.forEach(u=>{ if(u?.name) legacyNames.push(u.name); });
  const uniqueNames = [...new Set(legacyNames)].filter(Boolean);
  for(const name of uniqueNames){
    const oldTrades = JSON.parse(localStorage.getItem('te_trades_'+name)||'[]');
    const cfg = JSON.parse(localStorage.getItem('tv_cfg_'+name)||'{}');
    if(!oldTrades.length && !Object.keys(cfg).length) continue;
    try{
      const { data: inserted, error } = await supabaseClient.from('accounts').insert([{
        user_id: currentUserId,
        account_name: name,
        broker: 'Legacy',
        account_size: cfg.accountSize||0,
        daily_loss: cfg.dailyLoss||0,
        max_drawdown: cfg.drawdown||0,
        profit_target: 0,
        status: 'Active',
        created_at: new Date().toISOString()
      }]).select().single();
      if(error) throw error;
      const accountId = inserted?.id;
      if(accountId && oldTrades.length){
        const imported = oldTrades.map(t=>({
          account_id: accountId,
          date: t.date,
          asset: t.asset,
          market: t.market,
          direction: t.dir || t.direction || '',
          entry: t.entry,
          exit: t.exit,
          pnl: t.pnl,
          created_at: t.created_at || new Date().toISOString()
        }));
        await supabaseClient.from('trades').insert(imported);
      }
    }catch(e){
      console.warn('Legacy migration failed for', name, e);
    }
  }
  localStorage.setItem('legacy_data_migrated_'+currentUserId,'1');
}

