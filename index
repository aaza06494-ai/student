<script>

// ===== AUTH =====
let currentUserId = null;
let currentUser = null;
let currentAccount = null;
let accounts = [];
let accountDraftId = null;
let trades = [];
let checklists = [];
let templates = {};
let authInitialized = false;
let authStateChangeSubscription = null;

function _isSupabasePermissionDeniedError(err){
  if(!err) return false;
  const msg = String(err?.message || err?.code || err?.details || err).toLowerCase();
  return msg.includes('permission denied') || msg.includes('42501') || msg.includes('insufficient privilege');
}

const CACHE_VERSION = 2;
const CACHE_PREFIX = 'tv';

function getCacheKey(type, userId, accountId){
  const uid = normalizeUsername(userId || currentUserId || '_anon');
  const accountFragment = accountId ? `_${accountId}` : '';
  return `${CACHE_PREFIX}_${type}_v${CACHE_VERSION}_${uid}${accountFragment}`;
}

function safeParseJSON(value, fallback){
  if(!value) return fallback;
  try{ return JSON.parse(value); }catch(e){ return fallback; }
}

function saveCache(type, data, accountId){
  if(!currentUserId) return;
  const key = getCacheKey(type, currentUserId, accountId);
  localStorage.setItem(key, JSON.stringify({
    version: CACHE_VERSION,
    userId: currentUserId,
    accountId: accountId || null,
    timestamp: new Date().toISOString(),
    data
  }));
}

function loadCache(type, fallback, accountId){
  const key = getCacheKey(type, currentUserId, accountId);
  const envelope = safeParseJSON(localStorage.getItem(key), null);
  if(!envelope || envelope.version !== CACHE_VERSION || envelope.userId !== currentUserId || (accountId && envelope.accountId !== accountId)){
    return fallback;
  }
  return envelope.data === undefined ? fallback : envelope.data;
}

function removeCache(type, accountId){
  const key = getCacheKey(type, currentUserId, accountId);
  localStorage.removeItem(key);
}

function escapeHTML(value){
  return String(value || '').replace(/[&<>"']/g, ch => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch]));
}

function safeString(value){
  return value == null ? '' : String(value);
}

function safeNumber(value){
  const n = parseFloat(value);
  return Number.isFinite(n) ? n : 0;
}

function getTradeTimestamp(trade){
  return Date.parse(trade._localUpdatedAt || trade.updated_at || trade.created_at || '') || 0;
}

function normalizeTrade(trade){
  return {
    ...trade,
    asset: safeString(trade.asset),
    market: safeString(trade.market),
    dir: safeString(trade.dir),
    result: safeString(trade.result),
    quality: safeString(trade.quality),
    strategy: safeString(trade.strategy),
    sessionTag: safeString(trade.sessionTag),
    date: safeString(trade.date),
    time: safeString(trade.time),
    entry: safeString(trade.entry),
    exit: safeString(trade.exit),
    sl: safeString(trade.sl),
    tp: safeString(trade.tp),
    pnl: safeString(trade.pnl),
    notes: safeString(trade.notes),
    created_at: trade.created_at || new Date().toISOString(),
    updated_at: trade.updated_at || trade.created_at || new Date().toISOString(),
    _localUpdatedAt: trade._localUpdatedAt || trade.updated_at || trade.created_at || new Date().toISOString()
  };
}

function resolveTradeConflict(localTrade, remoteTrade){
  if(!remoteTrade) return localTrade;
  const localTs = getTradeTimestamp(localTrade);
  const remoteTs = getTradeTimestamp(remoteTrade);
  if(localTs >= remoteTs){
    return { ...remoteTrade, ...localTrade, updated_at: localTrade._localUpdatedAt || localTrade.updated_at || remoteTrade.updated_at || localTrade.created_at };
  }
  return { ...localTrade, ...remoteTrade, updated_at: remoteTrade.updated_at || localTrade.updated_at || localTrade.created_at };
}

function loadLocalAccounts(){
  return loadCache('accounts', [], null);
}

function saveLocalAccounts(){
  if(!currentUserId) return;
  saveCache('accounts', accounts, null);
}

function loadLocalTrades(accountId){
  return loadCache('trades', [], accountId).map(normalizeTrade);
}

function saveLocalTrades(accountId){
  if(!accountId) return;
  const saved = trades.map(t => ({
    ...normalizeTrade(t),
    _localUpdatedAt: new Date().toISOString(),
    updated_at: new Date().toISOString(),
    created_at: t.created_at || new Date().toISOString()
  }));
  saveCache('trades', saved, accountId);
}

function loadLocalDeletedTradeIds(accountId){
  return loadCache('deleted_trades', [], accountId);
}

function saveLocalDeletedTradeIds(accountId, ids){
  if(!accountId) return;
  saveCache('deleted_trades', ids, accountId);
}

function mergeRemoteWithLocalTrades(accountId, remoteTrades){
  const cachedTrades = loadLocalTrades(accountId) || [];
  const deletedIds = loadLocalDeletedTradeIds(accountId) || [];
  const remoteById = Object.fromEntries((remoteTrades||[]).filter(t=>t && t.id).map(t=>[t.id, normalizeTrade(t)]));
  const merged = [];

  cachedTrades.forEach(localTrade => {
    if(!localTrade) return;
    if(localTrade.id){
      if(deletedIds.includes(localTrade.id)){
        delete remoteById[localTrade.id];
        return;
      }
      remoteById[localTrade.id] = resolveTradeConflict(localTrade, remoteById[localTrade.id] || null);
    } else {
      merged.push(localTrade);
    }
  });

  Object.values(remoteById).forEach(remoteTrade => {
    if(remoteTrade && !deletedIds.includes(remoteTrade.id)) merged.push(remoteTrade);
  });

  return merged;
}

function clearLocalDeletedTradeIds(accountId){
  if(!accountId) return;
  removeCache('deleted_trades', accountId);
}

function loadLocalChecks(accountId){
  return loadCache('checklist', [], accountId);
}

function saveLocalChecks(accountId){
  if(!accountId) return;
  saveCache('checklist', checklists, accountId);
}

function loadChecklistTemplates(){
  return loadCache('templates', {}, null);
}

function saveChecklistTemplates(templates){
  if(!currentUserId) return;
  saveCache('templates', templates, null);
}

function hideAuthScreens(){
  const appShell = document.getElementById('app-shell');
  const loginScreen = document.getElementById('login-screen');
  if(appShell) appShell.style.display = 'none';
  if(loginScreen) loginScreen.style.display = 'none';
}

function getAuthEmail(username){
  const normalized = normalizeUsername(username);
  return normalized.includes('@') ? normalized : `${normalized}@tradeversity.app`;
}

async function restoreSessionFromSupabase(session){
  if(!session || !session.user) return false;
  const authUser = session.user;
  const email = authUser.email || '';
  const username = normalizeUsername(email.split('@')[0] || localStorage.getItem('tv_username') || '');
  let userId = localStorage.getItem('tv_user_id');

  if(!userId && username){
    try{
      const { data, error } = await supabaseClient.from('users').select('id,username').eq('username', normalizeUsername(username)).single();
      if(data && data.id){
        userId = data.id;
      }
    }catch(err){
      console.warn('[auth] restoreSessionFromSupabase fallback lookup failed', err);
    }
  }

  if(!userId || !username){
    return false;
  }

  currentUserId = userId;
  currentUser = username;
  localStorage.setItem('tv_user_id', userId);
  localStorage.setItem('tv_username', username);
  return true;
}

async function handleSupabaseAuthStateChange(event, session){
  if(event === 'SIGNED_IN' && session && session.user){
    const restored = await restoreSessionFromSupabase(session);
    if(restored){
      await loadAccountList();
      const storedAccountId = localStorage.getItem('tv_account_id');
      if(accounts.length){
        const selectId = storedAccountId && accounts.some(a=>a.id===storedAccountId) ? storedAccountId : accounts[0].id;
        await selectAccount(selectId);
      }
      showApp();
      initApp();
      return;
    }
  }
  if(event === 'SIGNED_OUT' || event === 'USER_DELETED' || event === 'TOKEN_REFRESH_FAILED'){
    signOutLocal();
    showLogin();
  }
}

function initLoginHandlers(){
  const authBtn = document.getElementById('auth-action-btn');
  const toggleBtn = document.getElementById('toggle-auth-btn');
  const usernameInput = document.getElementById('login-username');
  const passInput = document.getElementById('login-password');
  const firstNameInput = document.getElementById('register-first-name');
  const lastNameInput = document.getElementById('register-last-name');

  if(authBtn) authBtn.addEventListener('click', handleAuthAction);
  if(toggleBtn) toggleBtn.addEventListener('click', toggleAuthMode);

  [usernameInput, passInput, firstNameInput, lastNameInput].forEach(el=>{
    if(!el) return;
    el.addEventListener('keydown', function(event){
      if(event.key === 'Enter'){
        event.preventDefault();
        handleAuthAction();
      }
    });
  });
}

function handleAuthAction(){
  const actionBtn = document.getElementById('auth-action-btn');
  if(actionBtn && actionBtn.textContent.trim().startsWith('Register')){
    return doRegister();
  }
  return doLogin();
}

function toggleAuthMode(){
  const title = document.getElementById('auth-mode-title');
  const actionBtn = document.getElementById('auth-action-btn');
  const toggleBtn = document.getElementById('toggle-auth-btn');
  const registerFields = document.getElementById('register-fields');
  if(!title || !actionBtn || !toggleBtn || !registerFields) return;

  const isLoginMode = actionBtn.textContent.trim().startsWith('Login');
  if(isLoginMode){
    registerFields.style.display = 'block';
    title.textContent = 'Register a new account';
    actionBtn.textContent = 'Register →';
    toggleBtn.textContent = 'Back to Login';
  } else {
    registerFields.style.display = 'none';
    title.textContent = 'Login to your account';
    actionBtn.textContent = 'Login →';
    toggleBtn.textContent = 'Create account';
  }
}

function showLogin(){
  document.getElementById('app-shell').style.display = 'none';
  document.getElementById('login-screen').style.display = 'flex';
}

function showApp(){
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('app-shell').style.display = 'flex';
}

function initApp(){
  const name = currentUser || 'Trader';
  const el = document.getElementById('sb-username');
  if(el) el.textContent = name;
  
  const av = document.getElementById('sb-avatar-letter');
  if(av) av.textContent = name[0].toUpperCase();
  
  renderDashboard();
  renderCalendar();
  renderJournal();
  renderChecklist();
  checkDailyReset();
  loadStudentResourcesAndFeedback().then(()=>{ checkFeedbackPopup(); });
}

function normalizeUsername(name){
  return String(name||'').trim().toLowerCase().replace(/\s+/g,'_');
}

async function hashPassword(username, password){
  const enc = new TextEncoder();
  const data = enc.encode(`${normalizeUsername(username)}:${password}`);
  const hashBuffer = await crypto.subtle.digest('SHA-256', data);
  return Array.from(new Uint8Array(hashBuffer)).map(b=>b.toString(16).padStart(2,'0')).join('');
}

function setSession(userId, username){
  currentUserId = userId;
  currentUser = username;
  localStorage.setItem('tv_user_id', userId);
  localStorage.setItem('tv_username', username);
}

function clearSession(){
  currentUserId = null;
  currentUser = null;
  currentAccount = null;
  localStorage.removeItem('tv_user_id');
  localStorage.removeItem('tv_username');
  localStorage.removeItem('tv_account_id');
}

async function doLogin(){
  const username = document.getElementById('login-username').value.trim();
  const password = document.getElementById('login-password').value;
  if(!username){ document.getElementById('login-username').focus(); return; }
  if(!password){ document.getElementById('login-password').focus(); return; }

  const normalizedUsername = normalizeUsername(username);
  try{
    const { data: legacyUser, error: legacyLookupError } = await supabaseClient.from('users').select('password_hash').eq('username', normalizedUsername).single();
    if(!legacyLookupError && legacyUser?.password_hash){
      return await doLegacyLogin(username, password);
    }
  }catch(e){
    console.warn('[auth] legacy user lookup failed', e);
  }

  const authEmail = getAuthEmail(username);
  try{
    const { data, error } = await supabaseClient.auth.signInWithPassword({ email: authEmail, password });
    if(error){
      console.warn('[auth] signInWithPassword failed, falling back to legacy login', error.message || error);
      return await doLegacyLogin(username, password);
    }
    if(data?.session && data.user){
      const normalized = normalizeUsername(username);
      const { data: existing, error: existingError } = await supabaseClient.from('users').select('id').eq('username', normalized).single();
      if(existingError && existingError.code !== 'PGRST116') throw existingError;
      if(existing && existing.id){
        setSession(existing.id, normalized);
      } else {
        const { data: newUser, error: insertError } = await supabaseClient.from('users').insert([{
          username: normalized,
          first_name: '',
          family_name: '',
          created_at: new Date().toISOString()
        }]).select().single();
        if(insertError) throw insertError;
        setSession(newUser.id, normalized);
      }
      await migrateLegacyData();
      await loadAccountList();
      const storedAccountId = localStorage.getItem('tv_account_id');
      if(accounts.length){
        const selectId = storedAccountId && accounts.some(a=>a.id===storedAccountId) ? storedAccountId : accounts[0].id;
        await selectAccount(selectId);
      }
      showApp();
      initApp();
    } else {
      throw new Error('Could not establish auth session');
    }
  }catch(err){
    if(err && err.message && err.message.toLowerCase().includes('invalid login credentials')){
      tvAlert('Login failed: username or password invalid.','error');
    } else {
      tvAlert('Login failed: '+(err.message||err),'error');
    }
  }
}

async function doLegacyLogin(username, password){
  try{
    const { data, error } = await supabaseClient.from('users').select('*').eq('username', normalizeUsername(username)).single();
    if(error && error.code !== 'PGRST116') throw error;
    if(!data){ tvAlert('Login failed: username or password invalid.','error'); return; }
    const hash = await hashPassword(username, password);
    if(data.password_hash !== hash){ tvAlert('Login failed: username or password invalid.','error'); return; }
    setSession(data.id, normalizeUsername(username));
    await migrateLegacyData();
    await loadAccountList();
    const storedAccountId = localStorage.getItem('tv_account_id');
    if(accounts.length){
      const selectId = storedAccountId && accounts.some(a=>a.id===storedAccountId) ? storedAccountId : accounts[0].id;
      await selectAccount(selectId);
    }
    showApp();
    initApp();
  }catch(err){
    tvAlert('Login failed: '+(err.message||err),'error');
  }
}

async function doRegister(){
