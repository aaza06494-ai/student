// Render account status cards based on user config and stats
function renderAccountBar(){
  const el = document.getElementById('account-bar');
  if(!el) return;
  const cfg = getUserCfg();
  const s = calcStats();

  const accountSize = cfg.accountSize || 0;
  const dailyLimit  = cfg.dailyLoss   || 0;
  const ddLimit     = cfg.drawdown    || 0;

  // Current balance
  const balance = accountSize + s.totalPnl;

  // Daily P&L (today) — net: profit counts positive, loss counts negative
  const today = new Date().toISOString().split('T')[0];
  const todayPnl = trades
    .filter(t=>t.date===today)
    .reduce((a,t)=>a+(parseFloat(t.pnl)||0),0);
  // dailyUsed = net loss amount today (if positive = lost money, if negative = in profit)
  const dailyUsed = -todayPnl; // negative todayPnl means losses > profits
  const dailyPct  = dailyLimit>0 ? Math.min(100, Math.max(0, dailyUsed)/dailyLimit*100) : 0;

  // Max drawdown: calculated from current balance vs account size (balance-based)
  const ddUsed = accountSize > 0 ? Math.max(0, accountSize - balance) : s.maxDD;
  const ddPct  = ddLimit>0 ? Math.min(100, ddUsed/ddLimit*100) : 0;

  const fmt = v=>'$'+Math.abs(v).toLocaleString('en',{minimumFractionDigits:2,maximumFractionDigits:2});
  const pnlColor = s.totalPnl>=0?'var(--green)':'var(--red)';
  const balColor = balance>=accountSize?'var(--green)':balance>=(accountSize*0.9)?'var(--amber)':'var(--red)';
  const dailyColor = todayPnl>0 ? 'var(--green)' : dailyPct>=90?'var(--red)':dailyPct>=70?'var(--amber)':'var(--red)';
  const ddColor    = ddPct>=90?'var(--red)':ddPct>=70?'var(--amber)':'var(--green)';

  const warn = (pct,type)=>{
    if(pct>=100) return `<span style="color:var(--red);font-size:10px">🚨 ${type} LIMIT HIT</span>`;
    if(pct>=90)  return `<span style="color:var(--red);font-size:10px">⚠ ${pct.toFixed(0)}% used — STOP</span>`;
    if(pct>=70)  return `<span style="color:var(--amber);font-size:10px">⚠ ${pct.toFixed(0)}% used</span>`;
    return `<span style="color:rgba(255,255,255,.25);font-size:10px">${pct.toFixed(1)}% used</span>`;
  };

  el.innerHTML = `
    <div class="acc-card" style="--acc-color:${balColor}">
      <div class="acc-card-label">Current Balance</div>
      <div class="acc-card-value" style="color:${balColor}">${accountSize>0?fmt(balance):'—'}</div>
      <div class="acc-card-sub">${accountSize>0?'Start: '+fmt(accountSize):'Set account size on login'}</div>
    </div>
    <div class="acc-card" style="--acc-color:${pnlColor}">
      <div class="acc-card-label">Total P&L</div>
      <div class="acc-card-value" style="color:${pnlColor}">${(s.totalPnl>=0?'+':'')}${fmt(s.totalPnl)}</div>
      <div class="acc-card-sub">${s.totalTrades} trades · ${s.wins}W ${s.losses}L</div>
    </div>
    <div class="acc-card" style="--acc-color:${dailyColor}">
      <div class="acc-card-label">Daily P&L</div>
      <div class="acc-card-value" style="color:${todayPnl>=0?'var(--green)':dailyColor}">${dailyLimit>0||todayPnl!==0 ? (todayPnl>=0?'+':'')+fmt(todayPnl) : '—'}</div>
      <div class="acc-card-sub">${dailyLimit>0?'Max Loss Limit: '+fmt(dailyLimit):'No daily limit set'}</div>
      ${dailyLimit>0?`<div class="acc-progress"><div class="acc-progress-fill" style="width:${dailyPct}%;background:${dailyColor}"></div></div>${warn(dailyPct,'DAILY')}`:'' }
    </div>
    <div class="acc-card" style="--acc-color:${ddColor}">
      <div class="acc-card-label">Max Drawdown</div>
      <div class="acc-card-value" style="color:${ddColor}">${ddLimit>0||ddUsed>0?fmt(ddUsed):'—'}</div>
      <div class="acc-card-sub">${ddLimit>0?'Limit: '+fmt(ddLimit):'No limit set'} ${accountSize>0?'· From balance':''}
      </div>
      ${ddLimit>0?`<div class="acc-progress"><div class="acc-progress-fill" style="width:${ddPct}%;background:${ddColor}"></div></div>${warn(ddPct,'DRAWDOWN')}`:'' }
    </div>`;
}

