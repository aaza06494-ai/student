async function loadStudentResourcesAndFeedback(){
  if(!currentUser) return;
  try{
    // 1. ALL archived reports — shared library visible to every student
    const { data: archivedData, error: err1 } = await supabaseClient
      .from('exports')
      .select('*')
      .order('created_at',{ascending:false});
    if(err1) throw err1;
    const allReports = (archivedData||[]).filter(r=>r.payload && r.payload.type==='report');
    const archived = allReports.filter(r=> r.payload && r.payload.archived===true);

    // 2. Only THIS student's feedback
    const myReports = allReports.filter(r=>
      r.student_name===currentUser || r.username===currentUser
    );
    const feedbacks = myReports.filter(r=> r.payload && r.payload.feedback && r.payload.feedback.sentAt);

    window.__studentFeedbacks = feedbacks;
    renderStudentResources(archived);
    renderStudentFeedback(feedbacks);
  }catch(e){ console.warn('Failed to load resources', e); }
}
function downloadResource(id){
  // find in window trades? fall back to fetch
  supabaseClient.from('exports').select('*').eq('id',id).single().then(res=>{
    const row = res.data; if(!row) tvAlert('Resource not found','warn');return;
    const p = row.payload||{};
    if(p.fileData){ const b = dataURLToBlob(p.fileData); if(!b) tvAlert('Invalid file','error');return; const a=document.createElement('a'); a.href=URL.createObjectURL(b); a.download = p.fileName||'report.pdf'; a.click(); }
    else if(p.fileUrl){ window.open(p.fileUrl,'_blank'); }
    else if(p.reportHtml){ // fallback render html to pdf
      const blob = new Blob([p.reportHtml],'text/html'); const a=document.createElement('a'); a.href=URL.createObjectURL(blob); a.download = (p.fileName||'report')+'.html'; a.click(); }
  }).catch(e=>{console.warn(e);tvAlert('Download failed','error');});
}

async function markFeedbackSeen(id){
  try{
    const { data, error } = await supabaseClient.from('exports').select('*').eq('id',id).single();
    if(error || !data) throw error||new Error('not found');
    const payload = data.payload || {};
    payload.feedback = payload.feedback || {};
    payload.feedback.seen = true;
    payload.feedback.updatedAt = new Date().toISOString();
    const upd = await supabaseClient.from('exports').update({ payload }).eq('id', id).select();
    if(upd.error) throw upd.error;
    // refresh lists
    loadStudentResourcesAndFeedback();
  }catch(e){ console.warn(e); tvAlert('Could not mark feedback seen','warn'); }
}

