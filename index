}
function toggleCheck(id){const c=checklists.find(x=>x.id===id);if(c)c.checked=!c.checked;save();renderChecklist();}
function deleteCheckItem(id){checklists=checklists.filter(c=>c.id!==id);save();renderChecklist();}
function resetChecks(cat){checklists.filter(c=>c.cat===cat).forEach(c=>c.checked=false);save();renderChecklist();}
