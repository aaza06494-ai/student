<script>
// ===== TV DIALOG SYSTEM - defined early, DOM elements added to body at load =====

// ── tvAlert: top-right toast
window.tvAlert = function(msg, type) {
  var color = type==="error" ? "var(--red)" : type==="warn" ? "var(--amber)" : "var(--green)";
  var bg    = type==="error" ? "rgba(255,71,87,0.14)" : type==="warn" ? "rgba(255,215,0,0.12)" : "rgba(0,242,255,0.10)";
  var bd    = type==="error" ? "rgba(255,71,87,0.35)"  : type==="warn" ? "rgba(255,215,0,0.30)"  : "rgba(0,242,255,0.25)";
  var icon  = type==="error" ? "&#x274C;" : type==="warn" ? "&#x26A0;&#xFE0F;" : "&#x2705;";
  var t = document.createElement("div");
  t.innerHTML = '<div style="display:flex;align-items:center;gap:10px;"><span style="font-size:15px;">'+icon+'</span><span>'+msg+'</span></div>';
  t.style.cssText = "position:fixed;top:24px;right:24px;background:"+bg+";border:1px solid "+bd+";color:var(--text);padding:13px 18px;border-radius:12px;font-family:var(--font-mono);font-size:13px;z-index:100001;max-width:380px;box-shadow:0 8px 32px rgba(0,0,0,0.5);opacity:1;transition:opacity .35s;";
  document.body.appendChild(t);
  setTimeout(function(){ t.style.opacity="0"; setTimeout(function(){ if(t.parentNode) t.parentNode.removeChild(t); }, 400); }, 3800);
};

// ── tvConfirm: promise-based confirm modal
(function(){
  var _res = null;
  var C = {
    "Delete this account? This cannot be undone.":     {icon:"&#x26A0;",  type:"danger", title:"Delete Account",    msg:"This will permanently remove the account and all its trades.",     ok:"Delete Account"},
    "Delete this trade?":                              {icon:"&#x1F5D1;", type:"danger", title:"Delete Trade",       msg:"This trade will be permanently removed from your journal.",        ok:"Delete Trade"},
    "Delete ALL trades? This cannot be undone.":       {icon:"&#x26A0;",  type:"danger", title:"Delete All Trades",  msg:"Every trade in this account will be permanently erased.",          ok:"Delete All"},
    "No trades found. Export empty profile for admin?":{icon:"&#x1F4E4;", type:"info",   title:"No Trades Found",    msg:"Your journal is empty. Export an empty profile to admin?",         ok:"Export Anyway"},
    "Some required checklist items are not completed. Save anyway?":{icon:"&#x26A0;", type:"warn", title:"Incomplete Checklist", msg:"Some required pre-trade items are not checked. Save anyway?", ok:"Save Anyway"}
  };
  function gc(msg){
    if(C[msg]) return C[msg];
    var m = msg.match(/^Load template "(.+)"\? Current checklist will be replaced\./);
    if(m) return {icon:"&#x1F4CB;",type:"warn",title:"Load Template",msg:'Loading <b style="color:#f0f0f5">&ldquo;'+m[1]+'&rdquo;</b> will replace your current checklist.',ok:"Load Template"};
    return {icon:"&#x2753;", type:"info", title:"Confirm", msg:msg, ok:"OK"};
  }
  window.tvConfirm = function(message){
    return new Promise(function(resolve){
      _res = resolve;
      var cfg = gc(message);
      var ov = document.getElementById("tv-confirm-overlay");
      var ic = document.getElementById("tv-confirm-icon");
      var ti = document.getElementById("tv-confirm-title");
      var ms = document.getElementById("tv-confirm-msg");
      var ok = document.getElementById("tv-confirm-ok");
      var ca = document.getElementById("tv-confirm-cancel");
      if(!ov){ resolve(false); return; }
      document.body.appendChild(ov);
      ic.innerHTML = cfg.icon;
      ic.className = cfg.type;
      ti.textContent = cfg.title;
      ms.innerHTML = cfg.msg;
      ok.textContent = cfg.ok;
      ok.className = cfg.type;
      ov.classList.add("active");
      ok.onclick = function(){ ov.classList.remove("active"); if(_res){_res(true); _res=null;} };
      ca.onclick = function(){ ov.classList.remove("active"); if(_res){_res(false); _res=null;} };
      ov.onclick = function(e){ if(e.target===ov){ ov.classList.remove("active"); if(_res){_res(false); _res=null;} } };
    });
  };
})();

// ── tvPrompt: promise-based input modal
(function(){
  var _res = null;
  window.tvPrompt = function(label, placeholder, okLabel){
    return new Promise(function(resolve){
      _res = resolve;
      var ov  = document.getElementById("tv-prompt-overlay");
      var inp = document.getElementById("tv-prompt-input");
      var tit = document.getElementById("tv-prompt-title");
      var sub = document.getElementById("tv-prompt-sub");
      var ok  = document.getElementById("tv-prompt-ok");
      var ca  = document.getElementById("tv-prompt-cancel");
      if(!ov){ resolve(null); return; }
      document.body.appendChild(ov);
      tit.textContent = label || "Enter a value";
      sub.textContent = placeholder ? 'e.g. "'+placeholder+'"' : "";
      inp.value = "";
      inp.placeholder = placeholder || "";
      ok.textContent = okLabel || "Save";
      ov.style.display = "flex";
      setTimeout(function(){ inp.focus(); }, 80);
      function done(val){ ov.style.display="none"; if(_res){ _res(val); _res=null; } }
      ok.onclick  = function(){ done(inp.value.trim() || null); };
      ca.onclick  = function(){ done(null); };
      ov.onclick  = function(e){ if(e.target===ov) done(null); };
      inp.onkeydown = function(e){ if(e.key==="Enter") done(inp.value.trim()||null); if(e.key==="Escape") done(null); };
    });
  };
})();
</script>
</head>
