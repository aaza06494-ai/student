// ===== UNIVERSAL CONVERTER (AI + Heuristics) =====
const UniversalConverter = (function(){
  const canonical = {
    date: ['date','tradedate','timestamp','time','open time','entry time','close time','placed time','placing time','filled time','createdat'],
    symbol: ['symbol','instrument','asset','pair','market','contract','ticker'],
    side: ['side','direction','buy/sell','type'],
    entry: ['entry','entryprice','openprice','avgentry','fillprice','price','open'],
    exit: ['exit','exitprice','closeprice','avgexit','close','fillprice'],
    size: ['size','lots','lotsize','quantity','contracts','volume','qty','amount'],
    pnl: ['pnl','pl','profit','profitloss','netprofit','result','gain','loss']
  };

  function norm(h){ return String(h||'').toLowerCase().replace(/[^a-z0-9]/g,''); }
  function levenshtein(a,b){ if(a===b) return 0; if(!a) return b.length; if(!b) return a.length; const m=a.length,n=b.length; const d=Array(m+1).fill(0).map(()=>Array(n+1).fill(0)); for(let i=0;i<=m;i++)d[i][0]=i; for(let j=0;j<=n;j++)d[0][j]=j; for(let i=1;i<=m;i++)for(let j=1;j<=n;j++){ const c=a[i-1]===b[j-1]?0:1; d[i][j]=Math.min(d[i-1][j]+1,d[i][j-1]+1,d[i-1][j-1]+c);} return d[m][n]; }

  function mapHeader(h){ const nh=norm(h); if(!nh) return null; for(const key in canonical){ for(const alt of canonical[key]){ const na=norm(alt); if(na===nh) return key; if(na.includes(nh) || nh.includes(na)) return key; if(levenshtein(na,nh)<=2) return key; } } if(/qty|quant/.test(nh)) return 'size'; if(/pric|px/.test(nh)) return nh.includes('close')? 'exit' : 'entry'; if(/symb|inst|tick/.test(nh)) return 'symbol'; if(/pnl|profit|gain|loss/.test(nh)) return 'pnl'; return null; }

  function detectDelimiter(text){ const sample=text.split('\n').slice(0,5).join('\n'); if(/\t/.test(sample)) return '\t'; if(/;/.test(sample) && !/,/.test(sample)) return ';'; const pipes=(sample.match(/\|/g)||[]).length, commas=(sample.match(/,/g)||[]).length; if(pipes===0 && commas===0) return ''; return pipes>commas?'|':','; }

  function splitCSV(line, sep){ const out=[]; let cur='', inQ=false; for(let i=0;i<line.length;i++){ const ch=line[i]; if(ch==='"'){ inQ=!inQ; continue; } if(ch===sep && !inQ){ out.push(cur); cur=''; } else cur+=ch; } out.push(cur); return out.map(s=>s.trim()); }

  function parseNumber(v){ if(v===null||v===undefined||v==='') return 0; let s=String(v).trim().replace(/[−–—]/g,'-'); const neg=/^\(.*\)$/.test(s); s=s.replace(/[\$£€]/g,'').replace(/[()\s]/g,''); if(/\d+\.\d{3},\d+/.test(s) || (s.indexOf(',')>0 && s.indexOf('.')>0 && s.lastIndexOf(',')>s.lastIndexOf('.'))){ s=s.replace(/\./g,'').replace(/,/g,'.'); } else s=s.replace(/,/g,''); const n=parseFloat(s); return neg? -Math.abs(n || 0): (n || 0); }

  function normalizeDate(s){ if(!s) return ''; s=String(s).trim(); const ymd=s.match(/^(\d{4})[-\/\.](\d{1,2})[-\/\.](\d{1,2})/); if(ymd) return `${ymd[1]}-${ymd[2].padStart(2,'0')}-${ymd[3].padStart(2,'0')}`; const dmy=s.match(/^(\d{1,2})[\/\.](\d{1,2})[\/\.](\d{2,4})/); if(dmy){ let yy=parseInt(dmy[3],10); if(yy<100) yy += 2000; return `${yy}-${String(dmy[1]).padStart(2,'0')}-${String(dmy[2]).padStart(2,'0')}`; } return s; }

  function parseCSVGeneric(text){
    const sep = detectDelimiter(text);
    if(!sep) return {trades:[]};
    const rawLines = text.split('\n').map(l=>l.replace(/\r/g,'').trim()).filter(l=>l);
    const lines = rawLines.map(l=> l.replace(/(\$)?(\d{1,3}(?:,\d{3})+(?:\.\d+)?)/g, s=>s.replace(/,/g,'')) ).filter(l=>l);
    if(lines.length<1) return {trades:[]};
    const headers = splitCSV(lines[0], sep);
    const headerVotes = headers.reduce((v,h)=> v + (mapHeader(h)?1:0), 0);
    if(/\bSYM[:=]|\bOP[:=]|\bCL[:=]|\bQ[:=]|\bG[:=]/i.test(lines[0]) || headerVotes===0) return {trades:[]};
    if(/\d{4}-\d{2}-\d{2}|\d{1,2}[\/\.]\d{1,2}[\/\.]\d{2,4}/.test(lines[0]) && /\b(bought|sold|profit|pnl|entry|exit)\b/i.test(lines[0])) return {trades:[]};

    const mapped = headers.map(mapHeader);
    for(let j=0;j<headers.length;j++){
      const lh = headers[j].toLowerCase();
      if(lh.includes('open') && lh.includes('time')) mapped[j]='date';
      if(lh.includes('close') && lh.includes('time')) mapped[j]='date';
      if(lh.includes('open') && lh.includes('price')) mapped[j]='entry';
      if(lh.includes('buyprice')||lh.includes('buy price')) mapped[j]='entry';
      if(lh.includes('sellprice')||lh.includes('sell price')) mapped[j]='exit';
      if(lh.includes('close') && lh.includes('price')) mapped[j]='exit';
    }
    const entryIdxs = mapped.map((m,i)=>m==='entry'?i:-1).filter(i=>i>=0);
    const exitIdxs = mapped.map((m,i)=>m==='exit'?i:-1).filter(i=>i>=0);
    if(exitIdxs.length===0 && entryIdxs.length>=2) mapped[entryIdxs[1]]='exit';

    const cols = [];
    for(let i=1;i<lines.length;i++){
      let parts = splitCSV(lines[i], sep);
      if(parts.length > mapped.length){
        let merged=true;
        while(parts.length > mapped.length && merged){
          merged=false;
          for(let j=0;j<parts.length-1;j++){
            const cand = parts[j] + ',' + parts[j+1];
            if(/^\$?\d{1,3}(?:,\d{3})+(?:\.\d+)?$/.test(cand.trim())){
              parts[j]=cand; parts.splice(j+1,1); merged=true; break;
            }
          }
        }
      }
      for(let j=0;j<parts.length;j++){ if(!cols[j]) cols[j]=[]; cols[j].push(parts[j]); }
    }
    const dateRe = /\d{4}-\d{2}-\d{2}|\d{1,2}[\/\.]\d{1,2}[\/\.]\d{2,4}/;
    const symbolRe = /^[A-Z][A-Z0-9_!:.-]{1,}$/;
    const numRe = /[-+]?\d+[\.,]?\d*/;
    const colScores = cols.map(samples=>{
      const n = samples?samples.length:0; if(n===0) return {date:0,symbol:0,side:0,numeric:0,pnl:0};
      const date_c = samples.filter(v=>dateRe.test(v)).length / n;
      const sym_c = samples.filter(v=>symbolRe.test(v)).length / n;
      const side_c = samples.filter(v=>['buy','sell','long','short'].includes((v||'').toLowerCase())).length / n;
      const num_c = samples.filter(v=>numRe.test(v)).length / n;
      const pnl_c = samples.filter(v=>/\$|\(|\)|pnl|profit|loss/i.test(v) || (numRe.test(v) && Math.abs(parseNumber((v.match(numRe)||['0'])[0]))>0)).length / n;
      return {date:date_c,symbol:sym_c,side:side_c,numeric:num_c,pnl:pnl_c};
    });
    if(colScores.length){
      let bestDate = colScores.map(s=>s.date).indexOf(Math.max(...colScores.map(s=>s.date)));
      if(bestDate>=0 && !mapped[bestDate] && !mapped.includes('date')) mapped[bestDate]='date';
      let bestSym = colScores.map(s=>s.symbol).indexOf(Math.max(...colScores.map(s=>s.symbol)));
      if(bestSym>=0 && !mapped[bestSym] && !mapped.includes('symbol') && colScores[bestSym].symbol>0.3) mapped[bestSym]='symbol';
      let bestSide = colScores.map(s=>s.side).indexOf(Math.max(...colScores.map(s=>s.side)));
      if(bestSide>=0 && !mapped[bestSide] && colScores[bestSide].side>0.3) mapped[bestSide]='side';
      const numericOrder = colScores.map((s,i)=>[s.numeric,i]).sort((a,b)=>b[0]-a[0]).map(x=>x[1]);
      const assigned = new Set(mapped.map((m,i)=>m?i:null).filter(i=>i!==null));
      const numCandidates = numericOrder.filter(i=>!assigned.has(i));
      if(!mapped.includes('entry') && numCandidates.length>0 && !mapped[numCandidates[0]]) mapped[numCandidates[0]]='entry';
      if(!mapped.includes('exit') && numCandidates.length>1 && !mapped[numCandidates[1]]) mapped[numCandidates[1]]='exit';
      let bestPnl = colScores.map(s=>s.pnl).indexOf(Math.max(...colScores.map(s=>s.pnl)));
      if(bestPnl>=0 && colScores[bestPnl].pnl>0.4 && !mapped[bestPnl]) mapped[bestPnl]='pnl';
    }

    const trades=[];
    for(let i=1;i<lines.length;i++){
      let parts = splitCSV(lines[i], sep);
      if(parts.length > mapped.length){
        let merged=true;
        while(parts.length > mapped.length && merged){
          merged=false;
          for(let j=0;j<parts.length-1;j++){
            const cand = parts[j] + ',' + parts[j+1];
            if(/^\$?\d{1,3}(?:,\d{3})+(?:\.\d+)?$/.test(cand.trim())){
              parts[j]=cand; parts.splice(j+1,1); merged=true; break;
            }
          }
        }
      }
      const row={};
      for(let j=0;j<parts.length;j++){ const key = mapped[j]; if(key) row[key]=parts[j]; }
      const trade = {
        date: row.date||row.timestamp||'',
        symbol: row.symbol||'',
        side: row.side||'',
        entry: parseNumber(row.entry||row.price||''),
        exit: parseNumber(row.exit||''),
        size: parseNumber(row.size||row.qty||''),
        pnl: parseNumber(row.pnl||row.profit||'')
      };
      trades.push(trade);
    }
    return {trades};
  }

  async function aiExtract(text, endpoint=null, apiKey=null){
    // remote AI call if provided
    if(endpoint){
      try{
        const headers = {'Content-Type':'application/json'};
        if(apiKey) headers['Authorization']='Bearer '+apiKey;
        const resp = await fetch(endpoint, {method:'POST', headers, body:JSON.stringify({text}), mode:'cors'});
        if(!resp.ok) throw new Error('AI err '+resp.status);
        const j = await resp.json();
        return { trades: (j.trades||[]).map(t=>({ date: t.date||t.datetime||'', symbol: t.symbol||t.asset||'', side: t.side||t.dir||'', entry: parseNumber(t.entry), exit: parseNumber(t.exit), size: parseNumber(t.size), pnl: parseNumber(t.pnl), confidence: Number(t.confidence||t.score||0) })), warnings: j.warnings||[], errors: j.errors||[] };
      }catch(e){ return {trades:[],warnings:[],errors:[String(e)]}; }
    }
    // local heuristic fallback: key:value and sentence parsing
    try{
      const trades=[];
      const lines = text.split('\n').map(l=>l.replace(/\r/g,'').trim()).filter(l=>l).map(l=> l.replace(/(\$)?(\d{1,3}(?:,\d{3})+(?:\.\d+)?)/g, s=>s.replace(/,/g,'')) );
      for(const line of lines){
        if(!line || line.length<3) continue;
        const dateMatch = line.match(/(\d{4}-\d{2}-\d{2}|\d{1,2}[\/\.]\d{1,2}[\/\.]\d{2,4})/);
        const dateValue = dateMatch ? normalizeDate(dateMatch[1]) : '';
        // key:value style
        if(line.includes(':') && (/SYM[:=]|OP[:=]|CL[:=]|Q[:=]|G[:=]/i.test(line))){
          const parts = line.split(/\||,|\s+/).filter(p=>p.includes(':'));
          const obj = {date: dateValue, symbol:'', side:'', entry:0, exit:0, size:0, pnl:0};
          parts.forEach(p=>{ const [k,v] = p.split(':',2); if(!k||!v) return; const kk=k.trim().toLowerCase(); const vv=v.trim(); if(kk.startsWith('sym')) obj.symbol=vv; else if(kk.startsWith('op')||kk.startsWith('entry')) obj.entry=parseNumber(vv); else if(kk.startsWith('cl')||kk.startsWith('exit')) obj.exit=parseNumber(vv); else if(kk==='q' || kk.startsWith('qty') || kk.startsWith('size')) obj.size=parseNumber(vv); else if(kk.startsWith('pnl')||kk.startsWith('g')||kk.startsWith('profit')) obj.pnl=parseNumber(vv); else if(kk.startsWith('date')) obj.date=normalizeDate(vv); else if(kk.startsWith('side')) obj.side=vv; });
          if(!obj.side){ if(/\bshort\b/i.test(line)) obj.side='Sell'; else if(/\b(long|buy|bought)\b/i.test(line)) obj.side='Buy'; }
          const v = validate(obj); obj._confidence = v.confidence; obj._errors = v.errors; trades.push(obj); continue;
        }
        const symMatch = line.match(/\b([A-Z]{1,6}[A-Z0-9_!:.-]*)\b/);
        const entryMatch = line.match(/(?:buy(?:t|ed)?(?: at)?|op[:=]\s*|entry[:=]?|entry\s)([-+]?\d+[\.,]?\d*)/i);
        const exitMatch = line.match(/(?:sell(?:ed)?(?: at)?|sold at|cl[:=]\s*|exit[:=]?|exit\s|->|to)\s*([-+]?\d+[\.,]?\d*)/i);
        const pnlMatch = line.match(/(?:pnl[:=]?|profit[:=]?|g[:=]?|pnL|p\/l)\s*([-+]?\d+[\.,]?\d*)/i);
        const rangeMatch = line.match(/\b(?:long|short)\s+([-+]?\d+[\.,]?\d*)\s*(?:->|to)\s*([-+]?\d+[\.,]?\d*)/i);
        const nums = (line.match(/[-+]?\d{1,3}(?:[\.,]\d{3})*(?:[\.,]\d+)?/g)||[]).map(n=>parseNumber(n));
        const obj = {date: dateValue, symbol: symMatch?symMatch[1]:'', side:'', entry:0, exit:0, size:0, pnl:0};
        if(/\bshort\b/i.test(line)) obj.side='Sell'; else if(/\b(long|buy|bought)\b/i.test(line)) obj.side='Buy';
        if(entryMatch) obj.entry = parseNumber(entryMatch[1]);
        if(exitMatch) obj.exit = parseNumber(exitMatch[1]);
        if(pnlMatch) obj.pnl = parseNumber(pnlMatch[1]);
        if(!obj.entry && rangeMatch){ obj.entry = parseNumber(rangeMatch[1]); obj.exit = parseNumber(rangeMatch[2]); }
        if(!obj.entry && nums.length >= 2){ obj.entry = nums[0]; obj.exit = nums[1]; }
        if(!obj.pnl && nums.length >= 3){ obj.pnl = nums[nums.length-1]; }
        const v = validate(obj); obj._confidence = v.confidence; obj._errors = v.errors; trades.push(obj);
      }
      return {trades, warnings: trades.length?['ai_local_heuristic_used']:[], errors:[]};
    }catch(e){ return {trades:[],warnings:[],errors:[String(e)]}; }
  }

  function _normalizeOrderSide(side){
    if(!side) return '';
    const s = String(side).trim().toLowerCase();
    if(/^(buy|long)$/.test(s)) return 'Buy';
    if(/^(sell|short)$/.test(s)) return 'Sell';
    return '';
  }

  function _normalizeOrderSymbol(symbol){ return String(symbol||'').replace(/^[A-Z0-9_]+:/,'').trim(); }

  function _orderEventFromParsed(row){
    const side = _normalizeOrderSide(row.side||row.dir||row.action||'');
    const symbol = _normalizeOrderSymbol(row.symbol||row.asset||row.sym||row.instrument||'');
    if(!side || !symbol) return null;
    const entry = Number(row.entry||row.open||0) || 0;
    const exit = Number(row.exit||row.close||0) || 0;
    const qty = Math.max(1, Number(row.size||row.qty||row.quantity||0) || 1);
    let price = 0;
    if(entry && !exit) price = entry;
    else if(exit && !entry) price = exit;
    else price = Number(row.price||row.fillPrice||row.fillprice||0) || 0;
    if(!price) return null;
    return { date: row.date||row.timestamp||'', symbol, side, qty, price, entry, exit };
  }

  function _isOrderOnlyHistory(trades){
    if(!trades || trades.length < 2) return false;
    let partials = 0;
    trades.forEach(t=>{
      const entry = Number(t.entry||0);
      const exit = Number(t.exit||0);
      if((entry && !exit) || (!entry && exit)) partials++;
    });
    return partials >= Math.max(2, Math.floor(trades.length / 2));
  }

  function _fifoReconstructOrders(orders){
    const sorted = [...orders].sort((a,b)=> new Date(a.date||'').getTime() - new Date(b.date||'').getTime());
    const queues = {};
    const done = [];
    sorted.forEach(order=>{
      if(!order.side || !order.qty || !order.price) return;
      const symbolKey = order.symbol || '__MISSING_SYMBOL__';
      if(!queues[symbolKey]) queues[symbolKey]=[];
      const queue = queues[symbolKey];
      const opposite = order.side==='Buy'?'Sell':'Buy';
      let remaining = order.qty;
      while(remaining > 0){
        const mi = queue.findIndex(x=>x.side===opposite);
        if(mi < 0) break;
        const match = queue[mi];
        const matchQty = Math.min(remaining, match.qty);
        const isLong = match.side==='Buy';
        const entry = match.price;
        const exit = order.price;
        const pnl = isLong ? (exit-entry)*matchQty : (entry-exit)*matchQty;
        done.push({ date: order.date||match.date||'', symbol: order.symbol, side: isLong?'Buy':'Sell', entry, exit, size: matchQty, pnl: Number(pnl.toFixed(2)) });
        remaining -= matchQty;
        match.qty -= matchQty;
        if(match.qty <= 0) queue.splice(mi,1);
      }
      if(remaining > 0){
        queue.push({ date: order.date, symbol: order.symbol, side: order.side, qty: remaining, price: order.price });
      }
    });
    Object.values(queues).forEach(queue=> queue.forEach(open=>{
      done.push({ date: open.date||'', symbol: open.symbol, side: open.side, entry: open.price, exit: 0, size: open.qty, pnl: 0, _open:true });
    }));
    return done;
  }

  function _parseOrderOnlyLine(line){
    if(!line) return null;
    const dtMatch = line.match(/(\d{1,2}[\/\.\-]\d{1,2}[\/\.\-]\d{2,4})(?:\s+(\d{1,2}):(\d{2})(?::(\d{2}))?)?/);
    let date = '';
    if(dtMatch){
      date = normalizeDate(dtMatch[1]);
      if(dtMatch[2]){
        const hh = dtMatch[2].padStart(2,'0');
        const mm = dtMatch[3].padStart(2,'0');
        const ss = (dtMatch[4]||'00').padStart(2,'0');
        date = `${date}T${hh}:${mm}:${ss}`;
      }
    }
    const cleaned = line.replace(dtMatch?dtMatch[0]:'','').trim();
    const sideMatch = cleaned.match(/\b(buy|sell|long|short)\b/i);
    const side = sideMatch? _normalizeOrderSide(sideMatch[1]) : '';
    if(!side) return null;
    let symbol = '';
    const symbolMatch = cleaned.match(/\b([A-Z][A-Z0-9_!:.-]{1,7})\b/);
    if(symbolMatch) symbol = symbolMatch[1];
    if(!symbol){
      const anySym = cleaned.match(/\b([A-Z][A-Z0-9_!:.-]{1,7})\b/g)||[];
      for(const cand of anySym){
        if(!/^(buy|sell|long|short)$/i.test(cand)){ symbol=cand; break; }
      }
    }
    let qty = 1;
    let price = 0;
    const parts = cleaned.split(/\s+/).filter(Boolean);
    const sideIndex = parts.findIndex(p=>/^(buy|sell|long|short)$/i.test(p));
    if(sideIndex >= 0){
      if(parts[sideIndex+1]) qty = Number(parts[sideIndex+1].replace(/,/g,'')) || 1;
      if(parts[sideIndex+2]) price = parseNumber(parts[sideIndex+2]);
    }
    if(!price){
      const nums = cleaned.match(/[\d,]+(?:\.\d+)?/g)||[];
      if(nums.length >= 2){
        const last = nums[nums.length-1];
        const secondLast = nums[nums.length-2];
        price = secondLast.includes('.') || !last.includes('.') ? parseNumber(secondLast) : parseNumber(last);
      } else {
        price = nums.length? parseNumber(nums[0]) : 0;
      }
    }
    // Heuristic: if the chosen price is an extremely large integer, it's likely an order/ticket ID.
    // Prefer a numeric candidate that contains a decimal point or has a reasonable magnitude.
    if(price && Math.abs(price) > 1e8){
      const nums = cleaned.match(/[\d,]+(?:\.\d+)?/g)||[];
      // Prefer any candidate with a decimal point and reasonable size
      for(const n of nums){
        if(n && n.includes('.')){ const pn = parseNumber(n); if(Math.abs(pn) > 0 && Math.abs(pn) < 1e8){ price = pn; break; } }
      }
      // Otherwise prefer any numeric candidate with magnitude < 1e7
      if(Math.abs(price) > 1e8){
        for(const n of nums){ const pn = parseNumber(n); if(Math.abs(pn) > 0 && Math.abs(pn) < 1e7){ price = pn; break; } }
      }
    }
    if(!price) return null;
    return { date, symbol, side, qty, price };
  }

  function _parseOrderOnlyHistory(text){
    const lines = text.split('\n').map(l=>l.trim()).filter(l=>l);
    const events = lines.map(_parseOrderOnlyLine).filter(Boolean);
    if(lines.length === 1) return events;
    return events.length >= 2 && events.length >= Math.floor(lines.length/2) ? events : [];
  }

  function _normalizeTradeJournalDate(line){
    if(!line) return '';
    const m = line.match(/^(\d{1,2})\/(\d{1,2}),?\s*(\d{1,2}):(\d{2})(?::(\d{2}))?$/);
    if(!m) return normalizeDate(line);
    const month = m[1].padStart(2,'0');
    const day = m[2].padStart(2,'0');
    const hour = m[3].padStart(2,'0');
    const minute = m[4].padStart(2,'0');
    const second = (m[5]||'00').padStart(2,'0');
    const year = new Date().getFullYear();
    return `${year}-${month}-${day} ${hour}:${minute}:${second}`;
  }

  function _isTradeJournalDateLine(line){
    return /^\d{1,2}\/\d{1,2},?\s*\d{1,2}:\d{2}(?::\d{2})?$/.test(line);
  }

  function _isTradeJournalDirectionLine(line){
    if(!line) return false;
    const clean = line.toString().replace(/[^\x00-\x7F]/g,' ').replace(/[^a-zA-Z\s]/g,' ').toLowerCase();
    return /\b(long|short)\b/.test(clean);
  }

  function _normalizeTradeJournalDirection(dir){
    if(!dir) return '';
    const clean = dir.toString().replace(/[^\x00-\x7F]/g,' ').replace(/[^a-zA-Z\s]/g,' ').replace(/\s+/g,' ').trim().toLowerCase();
    if(clean.includes('long') || clean.includes('buy')) return 'Buy';
    if(clean.includes('short') || clean.includes('sell')) return 'Sell';
    return dir;
  }

  function _normalizeTradeJournalText(text){
    if(!text) return '';
    let clean = text.replace(/@TV/g,'');
    clean = clean.replace(/↗️|↘️|↖️|↙️|⇧|⇩|↑|↓|→|←/g,'');
    clean = clean.replace(/\$/g,'');
    clean = clean.replace(/,(?=\d{3}(?:\D|$))/g,'');
    clean = clean.replace(/\r/g,'');
    return clean.trim();
  }

  function _guessTradeJournalMarket(symbol){
    if(!symbol) return 'Unknown';
    const s = symbol.toString().toUpperCase();
    if(/^(MNQ|NQ|MES|ES|MGC|GC|CL|RTY)/.test(s)) return 'Futures';
    if(/^(BTC|ETH|SOL|XRP)/.test(s)) return 'Crypto';
    if(/^(EURUSD|GBPUSD|USDJPY|XAUUSD|US30|NAS100)/.test(s)) return 'CFD';
    return 'Unknown';
  }

  function _isTradeJournalExport(text){
    if(!text) return false;
    const normalized = _normalizeTradeJournalText(text).toLowerCase();
    if(/\bentrée\b/.test(normalized) || /\bsortie\b/.test(normalized) || /\bsymbole\b/.test(normalized) || /\bprix d'entrée\b/.test(normalized) || /\bprix de sortie\b/.test(normalized) || /\bp&l net\b/.test(normalized)){
      return true;
    }
    const lines = normalized.split('\n').map(l=>l.trim()).filter(l=>l);
    const dateCount = lines.filter(_isTradeJournalDateLine).length;
    const dirCount = lines.filter(l=>/long|short/i.test(l)).length;
    return dateCount >= 2 && dirCount >= 1 && lines.length >= 7;
  }

  function _parseTradeJournalExport(text){
    text = _normalizeTradeJournalText(text);
    const lines = text.split('\n').map(l=>l.trim()).filter(l=>l);
    const trades = [];
    if(!lines.length) return trades;

    const firstLower = lines[0].toLowerCase();
    if(firstLower.includes('entrée') && firstLower.includes('symbole') && firstLower.includes('p&l')){
      const sep = firstLower.includes('\t') ? '\\t' : (firstLower.includes(',') ? ',' : '\\s+');
      const headers = lines[0].split(new RegExp(sep)).map(h=>h.trim().toLowerCase());
      const indexOf = name => headers.findIndex(h=>name.some(n=>h.includes(n)));
      const dateIdx = indexOf(['entrée','entry','open']) !== -1 ? indexOf(['entrée','entry','open']) : 0;
      const assetIdx = indexOf(['symbole','symbol','asset']);
      const sideIdx = indexOf(['dir','direction','side']);
      const entryIdx = indexOf(["prix d'entrée","prix d entree","entry price","open price"]);
      const exitIdx = indexOf(["prix de sortie","exit price","close price"]);
      const pnlIdx = indexOf(['p&l net','pnl net','pnl','profit']);

      for(let i=1;i<lines.length;i++){
        const cols = lines[i].split(new RegExp(sep)).map(c=>c.trim());
        const symbol = cols[assetIdx] || '';
        const side = _normalizeTradeJournalDirection(cols[sideIdx] || '');
        const entry = parseNumber(cols[entryIdx] || '');
        const exit = parseNumber(cols[exitIdx] || '');
        const pnl = parseNumber(cols[pnlIdx] || '');
        const date = _normalizeTradeJournalDate(cols[dateIdx] || lines[i] || '');
        if(symbol && side && !Number.isNaN(entry) && !Number.isNaN(exit)){
          trades.push({date, asset:symbol, market:_guessTradeJournalMarket(symbol), side, entry, exit, pnl});
        }
      }
      return trades;
    }

    for(let i=0;i<lines.length; i++){
      if(!_isTradeJournalDateLine(lines[i]) || !_isTradeJournalDateLine(lines[i+1]) || !/^[A-Z0-9]{2,}$/i.test(lines[i+2])) continue;
      const maybeDirIndex = _isTradeJournalDirectionLine(lines[i+3]) ? i+3 : i+4;
      if(maybeDirIndex >= lines.length || !/long|short/i.test(lines[maybeDirIndex])) continue;
      if(maybeDirIndex + 7 >= lines.length) continue;
      const symbol = lines[i+2];
      const direction = _normalizeTradeJournalDirection(lines[maybeDirIndex]);
      const entry = parseNumber(lines[maybeDirIndex+2] || '');
      const exit = parseNumber(lines[maybeDirIndex+3] || '');
      const pnl = parseNumber(lines[maybeDirIndex+7] || '');
      if(symbol && direction && !Number.isNaN(entry) && !Number.isNaN(exit) && !Number.isNaN(pnl)){
        trades.push({
          date: _normalizeTradeJournalDate(lines[i]),
          asset: symbol,
          market: _guessTradeJournalMarket(symbol),
          side: direction,
          entry,
          exit,
          pnl
        });
        i = maybeDirIndex + 8;
      }
    }
    return trades;
  }

  function _reconstructOrderHistory(text, trades){
    if(!trades || !trades.length) return trades;
    const orderEvents = trades.map(_orderEventFromParsed).filter(Boolean);
    if(_isOrderOnlyHistory(orderEvents)){
      const complete = trades.filter(t=>{
        const entry = Number(t.entry||0);
        const exit = Number(t.exit||0);
        return !((entry && !exit) || (!entry && exit));
      });
      return complete.concat(_fifoReconstructOrders(orderEvents));
    }
    const rawOrders = _parseOrderOnlyHistory(text);
    if(rawOrders.length) return _fifoReconstructOrders(rawOrders);
    return trades;
  }

  function validate(t){
    const errors = [];
    let conf = 0.3;
    if(t && t.symbol && /[A-Z]/.test(String(t.symbol))) conf += 0.25; else errors.push('missing_symbol');
    if(t && t.date && /(\d{4}-\d{2}-\d{2}|\d{1,2}[\/\.]\d{1,2}[\/\.]\d{2,4})/.test(String(t.date))) conf += 0.2; else errors.push('invalid_date');
    if(t && t.side && /^(buy|sell|long|short)$/i.test(String(t.side))) conf += 0.1;
    let numCount = 0;
    if(typeof t.entry === 'number' && t.entry !== 0) { conf += 0.05; numCount++; }
    if(typeof t.exit === 'number' && t.exit !== 0) { conf += 0.05; numCount++; }
    if(typeof t.size === 'number' && t.size > 0) { conf += 0.05; numCount++; }
    conf = Math.max(0, Math.min(1, conf));
    return { valid: errors.length===0, errors, confidence: conf };
  }

  async function parseAsync(text, options={aiEndpoint:window.CONVERTER_AI_ENDPOINT||null, aiKey:window.CONVERTER_AI_KEY||null}){
    try{
      if(!text || !text.trim()) return {trades:[],warnings:['empty'],errors:[],summary:{}};
      // Try known detectors
      const lines=text.split('\n').map(l=>l.trim()).filter(l=>l);
      const sep = lines[0] && (lines[0].includes('\t')? '\t' : (lines[0].includes(',')? ',' : (lines[0].includes('|')? '|' : detectDelimiter(text))));
      const hdrs = sep ? lines[0].split(sep).map(h=>h.replace(/"/g,'').trim().toLowerCase()) : [];
      if(_isMT5CSV(hdrs)){
        const res=_convCaptureParse(()=>_parseMT5CSV(lines,sep,null),'MT5 Closed Positions');
        return {trades:res,warnings:[],errors:[],summary:{detected:'mt5',count:res.length}};
      }
      if(_isDXTradeCSV(hdrs)){
        const res=_convCaptureParse(()=>_parseDXTradeCSV(lines,sep,null),'DXTrade History');
        return {trades:res,warnings:[],errors:[],summary:{detected:'dxtrade',count:res.length}};
      }
      if(_isMatchTraderCSV(hdrs)){
        const res=_convCaptureParse(()=>_parseMatchTraderCSV(lines,sep,null),'MatchTrader');
        return {trades:res,warnings:[],errors:[],summary:{detected:'matchtrader',count:res.length}};
      }
      if(_isKMLCSV(hdrs)){
        const res=_convCaptureParse(()=>_parseKMLCSV(lines,sep,null),'KML/Tradovate');
        return {trades:res,warnings:[],errors:[],summary:{detected:'kml',count:res.length}};
      }
      if(_isTradingViewCSV(hdrs)){
        const res=_convCaptureParse(()=>_parseTradingViewCSV(lines,sep,null),'TradingView CSV');
        return {trades:res,warnings:[],errors:[],summary:{detected:'tv_csv',count:res.length}};
      }
      if(_isTVMultiline(text)){
        const res=_convCaptureParse(()=>_parseTVMultiline(text,null),'TradingView paste');
        return {trades:res,warnings:[],errors:[],summary:{detected:'tv_ml',count:res.length}};
      }
      if(_isTradeJournalExport(text)){
        const res = _parseTradeJournalExport(text);
        return {trades:res,warnings:[],errors:[],summary:{detected:'trade_journal',count:res.length}};
      }
      // Generic CSV
      const csv = parseCSVGeneric(text);
      if(csv.trades && csv.trades.length){
        let trades = csv.trades.map(t=>({...t}));
        trades = _reconstructOrderHistory(text, trades);
        const vt = trades.map(t=>{ const v=validate(t); return {...t, _errors:v.errors, _confidence:v.confidence}; });
        return {trades:vt, warnings:[], errors:[], summary:{detected:'csv',count:vt.length}};
      }
      const rawOrders = _parseOrderOnlyHistory(text);
      if(rawOrders.length){
        const trades = _fifoReconstructOrders(rawOrders);
        const vt = trades.map(t=>{ const v=validate(t); return {...t, _errors:v.errors, _confidence:v.confidence}; });
        return {trades:vt, warnings:['order_history'], errors:[], summary:{detected:'order_history',count:vt.length}};
      }
      // AI / heuristic fallback
      const ai = await aiExtract(text, options.aiEndpoint, options.aiKey);
      let trades = (ai.trades||[]).map(t=>({...t}));
      trades = _reconstructOrderHistory(text, trades);
      const vt = trades.map(t=>{ const v=validate(t); return {...t, _errors:v.errors, _confidence:t._confidence||v.confidence}; });
      return {trades:vt, warnings:ai.warnings, errors:ai.errors, summary:{detected:'ai',count:vt.length}};
    }catch(e){ return {trades:[],warnings:[],errors:[String(e)]}; }
  }

  return { parseAsync, aiExtract, validate };
})();

async function runConverter(){
  const text = document.getElementById('conv-input').value.trim();
  if(!text){ tvAlert('Paste some data first!','warn'); return; }
  const out = document.getElementById('conv-output');
  const bar = document.getElementById('conv-import-bar');
  const countBadge = document.getElementById('conv-count-badge');
  convParsedTrades = [];
  bar.style.display='none';
  out.innerHTML = '<div style="color:var(--text3);text-align:center">⏳ Processing...</div>';

  // ── Try built-in parsers first (fast, no AI needed) ──
  const lines = text.split('\n').map(l=>l.trim()).filter(l=>l);
  const sep   = lines[0].includes('\t')?'\t':',';
  const hdrs  = lines[0].split(sep).map(h=>h.replace(/"/g,'').trim().toLowerCase());

  let nativeResult = null;
  if(_isTVBalanceHistory(text)){
    nativeResult = _convCaptureParse(()=>_parseTVBalanceHistory(text,null), 'TradingView Balance History');
  } else if(_isMT5CSV(hdrs)){
    nativeResult = _convCaptureParse(()=>_parseMT5CSV(lines,sep,null), 'MT5 Closed Positions');
  } else if(_isDXTradeCSV(hdrs)){
    nativeResult = _convCaptureParse(()=>_parseDXTradeCSV(lines,sep,null), 'DXTrade History');
  } else if(_isMatchTraderCSV(hdrs)){
    nativeResult = _convCaptureParse(()=>_parseMatchTraderCSV(lines,sep,null), 'MatchTrader');
  } else if(_isKMLCSV(hdrs)){
    nativeResult = _convCaptureParse(()=>_parseKMLCSV(lines,sep,null), 'KML/Tradovate');
  } else if(_isTradingViewCSV(hdrs)){
    nativeResult = _convCaptureParse(()=>_parseTradingViewCSV(lines,sep,null), 'TradingView CSV');
  } else if(_isTVMultiline(text)){
    nativeResult = _convCaptureParse(()=>_parseTVMultiline(text,null), 'TradingView paste');
  }

  if(nativeResult && nativeResult.length>0){
    convParsedTrades = nativeResult.map(t => ({...t, _localUpdatedAt: new Date().toISOString()}));
    _convShowPreview(convParsedTrades, 'Auto-detected');
    return;
  }
  // ── Use UniversalConverter (AI + heuristics) as fallback ──
  try{
    out.innerHTML = '<div style="color:var(--text3);text-align:center">⏳ Trying advanced converter (heuristics + AI)...</div>';
    const uRes = await UniversalConverter.parseAsync(text);
    if(uRes && uRes.trades && uRes.trades.length){
      // Map to convParsedTrades shape
      convParsedTrades = uRes.trades.map(t=>({
        date: t.date||t.datetime||'',
        asset: t.symbol||t.asset||t.sym||'',
        dir: t.side||t.dir||'',
        entry: t.entry||0,
        exit: t.exit||0,
        size: t.size||0,
        pnl: t.pnl||0,
        confidence: t.confidence||t._confidence||0,
        _localUpdatedAt: new Date().toISOString()
      }));
      // show warnings/errors if any
      let infoHtml = '';
      if(uRes.warnings && uRes.warnings.length) infoHtml += '<div style="color:var(--amber);font-size:12px;margin-bottom:8px">Warnings: '+uRes.warnings.join('; ')+'</div>';
      if(uRes.errors && uRes.errors.length) infoHtml += '<div style="color:var(--red);font-size:12px;margin-bottom:8px">Errors: '+uRes.errors.join('; ')+'</div>';
      _convShowPreview(convParsedTrades, 'AI / Heuristic');
      if(infoHtml) out.insertAdjacentHTML('afterbegin', infoHtml);
      return;
    }
  }catch(e){ console.warn('UniversalConverter failed', e); }

  // ── Unknown format: show helpful error if AI didn't recover anything ──
  out.innerHTML = '<div style="color:var(--amber)">⚠ Format not recognized.<br><br><span style="font-size:12px;color:var(--text3);line-height:1.8">Expected format:<br><code style="color:var(--green);font-size:10px;background:var(--bg3);padding:8px;border-radius:4px;display:block;margin:8px 0">2026-04-20 13:47:10&nbsp;&nbsp;82016.17&nbsp;&nbsp;81416.17&nbsp;&nbsp;−600 USD<br/>Close short position for symbol CME_MINI:NQ1! at price 26747.00 for 1 units.<br/>Position AVG Price was 26717.00</code><br/><b style="color:var(--text)">Paste TradingView data, MT5 CSV, or broker statements.</b></span></div>';
}

// Capture trades parsed by native parsers without modifying the trades array
function _convCaptureParse(fn, label){
  const backup = [...trades];
  fn();
  const added = trades.filter(t=>!backup.find(b=>b.id===t.id));
  // Revert — we'll re-import on confirm
  trades.length = 0;
  backup.forEach(t=>trades.push(t));
  save();
  return added;
}

function _convShowPreview(list, source){
