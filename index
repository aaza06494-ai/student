<script>
window.__pendingFeedbackIds = [];

function checkFeedbackPopup(){
  const feedbacks = window.__studentFeedbacks || [];
  const unseen = feedbacks.filter(function(r){
    var fb = (r.payload||{}).feedback || {};
    return fb.sentAt && !fb.seen;
  });
  if(!unseen.length) return;
  var r = unseen[0];
  var fb = r.payload.feedback;
  window.__pendingFeedbackIds = unseen.map(function(x){ return x.id; });
  var rating = Number(fb.rating)||0;
  document.getElementById('fb-popup-stars').textContent = '★'.repeat(rating) + '☆'.repeat(5-rating);
  document.getElementById('fb-popup-comment').textContent = fb.comment || '(No comment)';
  var t = fb.sentAt ? new Date(fb.sentAt).toLocaleString() : '';
  document.getElementById('fb-popup-time').textContent = t ? 'Sent: '+t : '';
  var overlay = document.getElementById('feedback-popup-overlay');
  overlay.style.display = 'flex';
  document.getElementById('fb-popup-ok').onclick = async function(){
    overlay.style.display = 'none';
    for(var i=0;i<window.__pendingFeedbackIds.length;i++){
      try{ await markFeedbackSeen(window.__pendingFeedbackIds[i]); }catch(e){}
    }
    window.__pendingFeedbackIds = [];
    loadStudentResourcesAndFeedback();
  };
}
</script>



