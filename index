async function deleteTrade(i){
  if(!await tvConfirm('Delete this trade?')) return;
  const accountId = currentAccount?.id;
  const trade = trades[i];
  if(trade?.id && accountId){
    const deletedIds = loadLocalDeletedTradeIds(accountId);
    if(!deletedIds.includes(trade.id)) deletedIds.push(trade.id);
    saveLocalDeletedTradeIds(accountId, deletedIds);
  }
  trades.splice(i,1);
  save();
  saveLocalTrades(accountId);
  renderJournal();
}

// Delegated click handler — attached once on the static tbody element
function setupJournalRowClickDelegation(){
  const tbody = document.getElementById('journal-tbody');
  if(!tbody || tbody._tvClickAttached) return;
  tbody.addEventListener('click', function(e){
    if(e.target.closest('button, a, input, select, textarea')) return;
    const tr = e.target.closest('tr[data-filtered-idx]');
    if(!tr) return;
    const idx = tr.dataset.filteredIdx;
    if(idx !== undefined && idx !== null) showTradeDetailsPopupByFiltered(parseInt(idx, 10));
  });
  tbody._tvClickAttached = true;
}

async function deleteAllTrades(){
  if(!await tvConfirm('Delete ALL trades? This cannot be undone.')) return;
  const accountId = currentAccount?.id;
  if(accountId){
    const deletedIds = loadLocalDeletedTradeIds(accountId);
    trades.filter(t=>t?.id).forEach(t=>{ if(!deletedIds.includes(t.id)) deletedIds.push(t.id); });
    saveLocalDeletedTradeIds(accountId, deletedIds);
  }
  trades = [];
  save();
  saveLocalTrades(accountId);
  renderJournal();
  renderDashboard();
  renderCalendar();
}

function showTradeDetailsPopupByFiltered(filteredIdx){
    const t = (window._filteredTrades || [])[filteredIdx];
    if(!t){ console.warn('trade not found at filteredIdx', filteredIdx); return; }
    // find real index in trades array
    const realIdx = trades.indexOf(t);
    _showTradeDetailDirect(t, realIdx >= 0 ? realIdx : filteredIdx);
}

function openEditTradePopupByFiltered(filteredIdx){
    const t = (window._filteredTrades || [])[filteredIdx];
    if(!t) return;
    const realIdx = trades.indexOf(t);
    openEditTradePopup(realIdx >= 0 ? realIdx : filteredIdx);
}

function deleteTradeByFiltered(filteredIdx){
    const t = (window._filteredTrades || [])[filteredIdx];
    if(!t) return;
    const realIdx = trades.indexOf(t);
    deleteTrade(realIdx >= 0 ? realIdx : filteredIdx);
}

