<script>
// ===== SMART STORAGE — works in all browsers =====
(function(){
  // Storage wrapper with fallback
  const _mem = {};
  const nativeLocalStorage = window.localStorage;
  const storage = {
    getItem(k){ 
      try{ return nativeLocalStorage.getItem(k); }
      catch(e){ return _mem[k]||null; }
    },
    setItem(k,v){ 
      try{ nativeLocalStorage.setItem(k,v); }
      catch(e){ _mem[k]=v; }
    },
    removeItem(k){ 
      try{ nativeLocalStorage.removeItem(k); }
      catch(e){ delete _mem[k]; }
    },
    clear(){
      try{ nativeLocalStorage.clear(); }
      catch(e){ for(const key in _mem) delete _mem[key]; }
    },
    key(index){
      try{ return nativeLocalStorage.key(index); }
      catch(e){ return Object.keys(_mem)[index] || null; }
    },
    get length(){
      try{ return nativeLocalStorage.length; }
      catch(e){ return Object.keys(_mem).length; }
    }
  };
  // Override localStorage globally
  try{ 
    Object.defineProperty(window,'localStorage',{get:()=>storage,configurable:true}); 
  }catch(e){}
})();
</script>

