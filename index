// ===== TRADINGVIEW UNIVERSAL PARSER =====
// Handles ALL formats:
//  1. Multi-line paste (symbol / side / type / qty+prices / dates — each on own line)
//  2. Single-line CSV/TSV with headers
//  3. Junk lines at top (account balance, currency, %) → skipped automatically
//  4. Any broker prefix: BLACKBULL: CME_MINI: BINANCE: FX: → stripped
//  5. LONG and SHORT trades detected correctly via FIFO queue

function _tvDate(s){
  if(!s) return '';
  s=s.replace('T',' ').trim();
  if(/^\d{4}-\d{2}-\d{2}/.test(s)) return s.split(' ')[0];
  const p=s.split(' ')[0].split('/');
  if(p.length===3){
    if(p[2].length===4) return p[2]+'-'+p[0].padStart(2,'0')+'-'+p[1].padStart(2,'0');
    if(p[0].length===4) return p[0]+'-'+p[1].padStart(2,'0')+'-'+p[2].padStart(2,'0');
  }
  return s.split(' ')[0];
}
function _tvTime(s){ if(!s) return ''; return s.replace('T',' ').split(' ')[1]||''; }
function _tvMarket(sym){
  return /BTC|ETH|SOL|BNB|XRP|USDT/i.test(sym)?'Crypto'
        :/NQ|ES|YM|RTY|CL|GC|USTEC|NQ1/i.test(sym)?'Futures':'Forex';
}
function _tvClean(sym){ return (sym||'').replace(/^[A-Z0-9_]+:/,'').trim(); }
function _tvNum(s){ return parseFloat((s||'').toString().replace(/,/g,''))||0; }
function _guessMarket(sym){
  return /BTC|ETH|SOL|BNB|XRP|USDT/i.test(sym)?'Crypto'
        :/NQ|ES|YM|RTY|CL|GC|USTEC|NQ1/i.test(sym)?'Futures':'Forex';
}
function _guessSession(datetime){
  if(!datetime) return 'Other';
  const hour = parseInt(datetime.split(' ')[1]?.split(':')[0])||0;
  if(hour>=8 && hour<12) return 'London';
  if(hour>=12 && hour<21) return 'NY';
  if(hour<8) return 'Asia';
  return 'Other';
}
function _isDateStr(s){ return /^\d{4}-\d{2}-\d{2}[ T]/.test(s)||/^\d{2}\/\d{2}\/\d{4}/.test(s); }
function _isSide(s){ return /^(buy|sell)$/i.test((s||'').trim()); }
function _isOrdType(s){ return /^(market|limit|stop|stop limit)$/i.test((s||'').trim()); }
function _isTVSymbol(s){
  s=(s||'').trim();
  return s.length>=2 && /^[A-Z_]/.test(s) && !_isSide(s) && !_isOrdType(s)
      && !/^\d/.test(s) && !/^(USD|EUR|GBP|JPY|D|F|R)$/.test(s);
}

// Detect TV multi-line paste format
function _isTVMultiline(text){
  const ls=text.split('\n').map(l=>l.trim()).filter(l=>l);
  return ls.some(l=>_isSide(l)) && ls.some(l=>_isDateStr(l.split('\t')[0]));
}

// Detect TV single-line CSV/TSV with headers
function _isTradingViewCSV(headers){
  const sig=['symbol','side','fill price','placing time','closing time','filled time','placed time','quantity'];
  return sig.filter(h=>headers.includes(h)).length>=3;
}

// ── Multi-line paste parser ───────────────────────────────────────────────
function _parseTVMultiline(text, input){
  const rawLines = text.split('\n').map(l=>l.trim());
  const orders=[];
  let cur=null;

  for(let i=0;i<rawLines.length;i++){
    const line=rawLines[i];
    if(!line) continue;
    const tabs=line.split('\t');
    const first=tabs[0].replace(/,/g,'').trim();

    // Date line: first token looks like a datetime
    if(_isDateStr(first)){
      if(cur){
        cur.placingTime=first;
        cur.closingTime=(tabs[1]||'').trim();
        // capture ticket and reported P&L from remaining tabs
        const extras = tabs.slice(2).map(t=>t.trim()).filter(t=>t);
        // Last numeric value before 'USD' is often the reported account balance — skip
        // But a standalone number after ticket could be commission/pnl
        // We'll look for a numeric tab that appears to be P&L (after ticket number)
        // Actually: the balance (e.g. 34,806.98) after ticket is account balance, not pnl
        // We'll NOT use it — pnl will be calculated from prices
        orders.push(cur);
        cur=null;
      }
      continue;
    }

    // Side line
    if(_isSide(first)){
      if(cur) cur.side=first.toLowerCase();
      continue;
    }

    // Order type line
    if(_isOrdType(first)){
      if(cur) cur.orderType=first;
      continue;
    }

    // Qty+prices line: first token is a number (qty)
    const cleanFirst=first.replace(/,/g,'');
    const asNum=parseFloat(cleanFirst);
    if(!isNaN(asNum) && asNum>0 && cur && !cur.qty){
      // qty is first number, fillPrice is last price on this line
      cur.qty = asNum;
      const nums=tabs.map(t=>parseFloat(t.replace(/,/g,'').trim())).filter(n=>!isNaN(n)&&n>0);
      // For futures qty is small (1-100), for forex large (1000, 100000)
      // Fill price = the largest reasonable price value (not the qty itself if small)
      // Last numeric tab is usually the fill price
      if(nums.length>=2) cur.fillPrice=nums[nums.length-1];
      else if(nums.length===1) cur.fillPrice=nums[0];
      continue;
    }

    // Symbol line: start new order
    if(_isTVSymbol(first)){
      if(cur) orders.push(cur); // save incomplete
      cur={sym:_tvClean(first),side:'',orderType:'',qty:0,fillPrice:0,commission:0,placingTime:'',closingTime:''};
      continue;
    }
    // Currency line (USD, EUR) — marks end of order block
    if(line==='USD'||line==='EUR'||line==='GBP'){
      if(cur) { cur.currency=line; }
      continue;
    }
    // Standalone decimal number (like 1,999.06 or 34,806.98) — could be reported P&L or balance
    // We store the LAST such number before USD as potential context
    const maybeNum = parseFloat(line.replace(/,/g,''));
    if(!isNaN(maybeNum) && maybeNum>0 && cur && cur.fillPrice && !line.includes('\t')){
      cur._lastNum = maybeNum; // store for reference
      continue;
    }
    // Numeric line that could be account balance after trade
    // The pattern: large number appearing alone = account balance (NOT pnl)
    // Skip these
    // anything else → skip
  }
  if(cur) orders.push(cur);
  return _tvFinalizePairs(orders, input, 'TradingView');
}

// ── Single-line CSV parser ────────────────────────────────────────────────
function _parseTradingViewCSV(lines, sep, input){
  const headers=lines[0].split(sep).map(h=>h.replace(/"/g,'').trim().toLowerCase());
  const orders=[];
  for(let i=1;i<lines.length;i++){
    const cols=lines[i].split(sep).map(c=>c.replace(/"/g,'').trim());
    if(cols.length<3) continue;
    const row={};
    headers.forEach((h,idx)=>{row[h]=cols[idx]||'';});
    const side=(row['side']||'').toLowerCase();
    if(!_isSide(side)) continue;
    const status=(row['status']||'').toLowerCase();
    if(status&&status!=='filled') continue;
    const sym=_tvClean(row['symbol']||'');
    if(!sym) continue;
    orders.push({
      sym, side,
      qty:_tvNum(row['quantity']||row['qty']||'1'),
      fillPrice:_tvNum(row['fill price']||row['fillprice']||row['price']||'0'),
      commission:parseFloat(row['commission']||'0')||0,
      placingTime:row['placing time']||row['placed time']||row['time']||'',
      closingTime:row['closing time']||row['filled time']||row['close time']||''
    });
  }
  return _tvFinalizePairs(orders, input, 'TradingView');
}

// ── FIFO pair matcher ─────────────────────────────────────────────────────
function _tvFinalizePairs(orders, input, source){
  orders.sort((a,b)=>new Date(a.placingTime||0)-new Date(b.placingTime||0));
  const queues={}, done=[];
  orders.forEach(o=>{
    if(!o.sym||!o.side) return;
    if(!queues[o.sym]) queues[o.sym]=[];
    const q=queues[o.sym];
    const opp=o.side==='buy'?'sell':'buy';
    const mi=q.findIndex(x=>x.side===opp);
    if(mi>=0){
      const m=q.splice(mi,1)[0];
      const isLong=m.side==='buy';
      const eP=isLong?m.fillPrice:o.fillPrice;
      const xP=isLong?o.fillPrice:m.fillPrice;
      const qty=Math.min(m.qty||1,o.qty||1);
      // Use _lastNum from either order as reported P&L (TV shows it before USD line)
      const repPnl = m._lastNum || o._lastNum || null;
      let raw;
      if(repPnl && repPnl > 0){
        // Reported P&L is always positive in TV — determine sign from direction+prices
        const signCheck = isLong ? (xP - eP) : (eP - xP);
        raw = signCheck >= 0 ? repPnl : -repPnl;
      } else {
        // Fallback: calculate from price difference
        function _ptVal(sym){
          const s=(sym||'').toUpperCase().replace(/^[A-Z0-9]+:/,'');
          if(s.match(/^NQ|^MNQ/)) return 20;
          if(s.match(/^ES|^MES/)) return 50;
          if(s.match(/^RTY|^M2K/)) return 50;
          if(s.match(/^YM|^MYM/)) return 5;
          if(s.match(/^GC|^MGC/)) return 100;
          if(s.match(/^XAU/)) return 1;
          if(s.match(/^CL/)) return 1000;
          return 1;
        }
        const ptv = _ptVal(o.sym);
        raw = isLong?(xP-eP)*qty*ptv:(eP-xP)*qty*ptv;
      }
      const comm=Math.abs(m.commission||0)+Math.abs(o.commission||0);
      done.push({sym:o.sym,dir:isLong?'Buy':'Sell',entry:eP,exit:xP,qty,netPnl:raw-comm,
        entryTime:isLong?m.placingTime:o.placingTime,
        exitTime:isLong?o.closingTime:m.closingTime});
    } else { q.push(o); }
  });
  Object.values(queues).forEach(q=>q.forEach(o=>done.push({
    sym:o.sym,dir:o.side==='buy'?'Buy':'Sell',entry:o.fillPrice,exit:0,
    qty:o.qty||1,netPnl:0,entryTime:o.placingTime||o.closingTime,exitTime:'',_open:true
  })));

  const maxId=trades.length?Math.max(...trades.map(t=>t.id||0)):0;
  let nextId=maxId+1,imported=0;
  done.forEach(t=>{
    const date=_tvDate(t.entryTime),time=_tvTime(t.entryTime);
    const pnl=parseFloat((t.netPnl||0).toFixed(2));
    const dup=trades.find(x=>x.asset===t.sym&&x.date===date&&Math.abs(parseFloat(x.pnl)-pnl)<0.01&&String(x.entry)===String(t.entry));
    if(dup) return;
    trades.push({id:nextId++,date,time,asset:t.sym,market:_tvMarket(t.sym),session:'NY',
      dir:t.dir,entry:String(t.entry),exit:String(t.exit||''),sl:'',tp:'',risk:'',rr:'',
      pnl:String(pnl),result:pnl>0?'Win':pnl<0?'Loss':'BE',quality:'',
      strategy:'#TradingView',sessionTag:'',
      setup:t._open?'TradingView — open position':'Imported from TradingView',
      entryReason:'',exitReason:'',emotion:'',mistakes:'',lessons:'',_imported:true});
    imported++;
  });
  save();renderDashboard();renderCalendar();renderJournal();
  if(input) input.value='';
  _showToast(imported>0?`✅ ${imported} trade${imported>1?'s':''} imported from ${source}`:'⚠ No trades matched — check data',imported>0?'#00f2ff':'#ffd700');
}

function _showToast(msg, color){
  const toast = document.createElement('div');
  toast.textContent = msg;
  toast.style.cssText=`position:fixed;bottom:24px;right:24px;background:${color};color:#000;padding:12px 20px;border-radius:10px;font-weight:600;font-size:14px;z-index:9999;font-family:var(--font-mono)`;
  document.body.appendChild(toast);
  setTimeout(()=>toast.remove(), 3500);
}

// ===== KML / TRADOVATE PERFORMANCE CSV PARSER =====
// Columns: symbol,_priceFormat,_priceFormatType,_tickSize,buyFillId,sellFillId,qty,buyPrice,sellPrice,pnl,boughtTimestamp,soldTimestamp,duration
function _isKMLCSV(headers){
  const needed = ['symbol','buyprice','sellprice','pnl','boughttimestamp','soldtimestamp'];
  return needed.filter(h=>headers.includes(h)).length >= 5;
}

function _parseKMLCSV(lines, sep, input){
  const headers = lines[0].split(sep).map(h=>h.replace(/"/g,'').trim().toLowerCase());

  const maxId = trades.length ? Math.max(...trades.map(t=>t.id||0)) : 0;
  let nextId = maxId + 1;
  let imported = 0;

  function parsePnl(raw){
    // handles: "$1,120.00", "$(235.00)", "$700.00"
    if(!raw) return 0;
    const negative = raw.includes('(') && raw.includes(')');
    const num = parseFloat(raw.replace(/[$(),\s]/g,''))||0;
    return negative ? -num : num;
  }

  function normKMLDate(ts){
    // "05/11/2026 14:54:14" → "2026-05-11"
    if(!ts) return '';
    const [datePart] = ts.split(' ');
    if(!datePart) return '';
    const p = datePart.split('/');
    if(p.length===3){
      // MM/DD/YYYY
      if(p[2].length===4) return p[2]+'-'+p[0].padStart(2,'0')+'-'+p[1].padStart(2,'0');
      // DD/MM/YYYY fallback
      return p[2]+'-'+p[1].padStart(2,'0')+'-'+p[0].padStart(2,'0');
    }
    return datePart;
  }

  function normKMLTime(ts){
    if(!ts) return '';
    const parts = ts.split(' ');
    return parts[1]||'';
  }

  for(let i=1;i<lines.length;i++){
    // handle commas inside quoted pnl values like "$1,120.00"
    const cols = [];
    let cur='', inQuote=false;
    for(let c=0;c<lines[i].length;c++){
      const ch=lines[i][c];
      if(ch==='"'){ inQuote=!inQuote; continue; }
      if(ch===sep && !inQuote){ cols.push(cur.trim()); cur=''; }
      else cur+=ch;
    }
    cols.push(cur.trim());
    if(cols.length<5) continue;

    const row={};
    headers.forEach((h,idx)=>{ row[h]=cols[idx]!==undefined?cols[idx]:''; });

    const symbol = row['symbol']||'';
    if(!symbol) continue;

    const buyPrice  = parseFloat(row['buyprice'])||0;
    const sellPrice = parseFloat(row['sellprice'])||0;
    const qty       = parseFloat(row['qty'])||1;
    const pnl       = parsePnl(row['pnl']);
    const boughtTs  = row['boughttimestamp']||'';
    const soldTs    = row['soldtimestamp']||'';

    // Direction: if buyFillId is the "aggressor" (entry), check which timestamp is earlier
    // boughtTimestamp = when buy order filled, soldTimestamp = when sell order filled
    // If bought > sold → trader sold first (SHORT), otherwise LONG
    let dir = 'Buy';
    if(boughtTs && soldTs){
      const bt = new Date(boughtTs.replace(/(\d{2})\/(\d{2})\/(\d{4})/,'$3-$1-$2'));
      const st = new Date(soldTs.replace(/(\d{2})\/(\d{2})\/(\d{4})/,'$3-$1-$2'));
      // entry is the earlier timestamp
      if(bt < st){ dir='Buy'; } else { dir='Sell'; }
    }

    const entryTs = dir==='Buy' ? boughtTs : soldTs;
    const date    = normKMLDate(entryTs);
    const time    = normKMLTime(entryTs);
    const entry   = dir==='Buy' ? buyPrice : sellPrice;
    const exit    = dir==='Buy' ? sellPrice : buyPrice;

    // Duplicate check
    const dup = trades.find(t=>
      t.asset===symbol &&
      t.date===date &&
      Math.abs(parseFloat(t.pnl)-pnl)<0.01
    );
    if(dup) continue;

    let result = pnl>0 ? 'Win' : pnl<0 ? 'Loss' : 'BE';

    trades.push({
      id: nextId++,
      date,
      time,
      asset: symbol,
      market: 'Futures',
      session: 'NY',
      dir,
      entry: String(entry),
      exit:  String(exit),
      sl:'', tp:'',
      risk: String(Math.abs(pnl)),
      rr:'',
      pnl: String(pnl.toFixed(2)),
      result,
      quality:'',
      strategy:'#KML',
      sessionTag:'',
      setup:'Imported from KML/Tradovate',
      entryReason:'', exitReason:'',
      emotion:'', mistakes:'', lessons:'',
      _imported: true
    });
    imported++;
  }

  save();
  renderDashboard();
  renderCalendar();
  renderJournal();
  if(input) input.value='';
  _showToast(
    imported>0 ? `✅ ${imported} trades imported from KML` : '⚠ No trades found in KML file',
    imported>0 ? '#00f2ff' : '#ffd700'
  );
}

// ===== MT5 CLOSED POSITIONS PARSER =====
function _isMT5CSV(headers){
  const needed = ['ticket','type','optime','closetime','symbol','size','openprice','closeprice','profit'];
  return needed.filter(h=>headers.some(x=>x.includes(h))).length >= 6;
}

function _parseMT5CSV(lines, sep, input){
  const headers = lines[0].split(sep).map(h=>h.replace(/"/g,'').trim().toLowerCase());
  const maxId = trades.length ? Math.max(...trades.map(t=>t.id||0)) : 0;
  let nextId = maxId + 1;
  let imported = 0;

  const findIdx = (keywords) => headers.findIndex(h => keywords.some(k => h.includes(k)));
  const typeIdx = findIdx(['type']);
  const opTimeIdx = findIdx(['optime','opentime','open time','open date']);
  const closeTimeIdx = findIdx(['closetime','closingtime','close time','close date']);
  const symbolIdx = findIdx(['symbol','instrument']);
  const sizeIdx = findIdx(['size','volume','lots']);
  const openPriceIdx = findIdx(['openprice','open price']);
  const closePriceIdx = findIdx(['closeprice','close price']);
  const profitIdx = findIdx(['profit','pnl','pl']);

  for(let i=1;i<lines.length;i++){
    const cols = lines[i].split(sep).map(c=>c.replace(/"/g,'').trim());
    if(cols.length < 5) continue;

    const type = (cols[typeIdx]||'').toLowerCase();
    if(!/^(buy|sell|0|1)/.test(type)) continue;

    const symbol = cols[symbolIdx]||'';
    if(!symbol) continue;

    const openTime = cols[opTimeIdx]||'';
    const closeTime = cols[closeTimeIdx]||'';
    if(!openTime && !closeTime) continue;

    const openPrice = parseFloat(cols[openPriceIdx])||0;
    const closePrice = parseFloat(cols[closePriceIdx])||0;
    let profit = parseFloat((cols[profitIdx]||'').replace(/[^\d.-]/g,''))||0;

    const size = parseFloat(cols[sizeIdx])||1;
    
    // MT5 Type: 0=buy, 1=sell
    const dir = type==='0' || type.toLowerCase()==='buy' ? 'Buy' : 'Sell';
    
    // Parse date from MT5 timestamp format (2026.06.01 14:30:45 or 06/01/2026 14:30:45)
    let date = '';
    if(openTime){
      const dtMatch = openTime.match(/(\d{4}).(\d{1,2}).(\d{1,2})|(\d{1,2}).(\d{1,2}).(\d{4})/);
      if(dtMatch){
        if(dtMatch[1]) date = `${dtMatch[1]}-${dtMatch[2].padStart(2,'0')}-${dtMatch[3].padStart(2,'0')}`;
        else date = `${dtMatch[6]}-${dtMatch[4].padStart(2,'0')}-${dtMatch[5].padStart(2,'0')}`;
      }
    }
    if(!date) continue;

    // Extract time
    let time = '';
    const timeMatch = openTime.match(/(\d{1,2}):(\d{2})(?::(\d{2}))?/);
    if(timeMatch) time = `${timeMatch[1].padStart(2,'0')}:${timeMatch[2]}${timeMatch[3]?':'+timeMatch[3].padStart(2,'0'):''}`;

    const dup = trades.find(t=>t.asset===symbol && t.date===date && Math.abs(parseFloat(t.pnl)-profit)<0.01);
    if(dup) continue;

    trades.push({
      id:nextId++, date, time,
      asset:symbol, market:_guessMarket(symbol), session:_guessSession(date+' '+time),
      dir, entry:String(openPrice), exit:String(closePrice),
      sl:'', tp:'', risk:String(Math.abs(profit)), rr:'',
      pnl:String(profit.toFixed(2)), result:profit>0?'Win':profit<0?'Loss':'BE',
      quality:'', strategy:'#MT5', sessionTag:'',
      setup:'Imported from MT5 Closed Positions',
      entryReason:'', exitReason:'', emotion:'', mistakes:'', lessons:'',
      _imported:true
    });
    imported++;
  }

  save(); renderDashboard(); renderCalendar(); renderJournal();
  if(input) input.value='';
  _showToast(imported>0?`✅ ${imported} trades imported from MT5`:'⚠ No trades found in MT5 file', imported>0?'#00f2ff':'#ffd700');
}

// ===== DXTRADE HISTORY PARSER =====
function _isDXTradeCSV(headers){
  const needed = ['orderstatus','executionside','symbol','ordertime','executionprice','closeprice','profit'];
  return needed.filter(h=>headers.some(x=>x.includes(h))).length >= 5;
}

function _parseDXTradeCSV(lines, sep, input){
  const headers = lines[0].split(sep).map(h=>h.replace(/"/g,'').trim().toLowerCase());
  const maxId = trades.length ? Math.max(...trades.map(t=>t.id||0)) : 0;
