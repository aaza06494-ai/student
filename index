  };
  try{
    let newAccountId = null;
    if(accountDraftId){
      const { error: updErr } = await supabaseClient.from('accounts').update(payload).eq('id', accountDraftId);
      if(updErr) throw updErr;
    } else {
      payload.created_at = new Date().toISOString();
