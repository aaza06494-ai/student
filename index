function saveCheckItem(){
  const text=document.getElementById('ci-text').value.trim();
  if(!text) return;
  checklists.push({id:Date.now(),text,cat:document.getElementById('ci-cat').value,type:document.getElementById('ci-type').value,checked:false});
  save();renderChecklist();closeModal('modal-check-item');
  document.getElementById('ci-text').value='';
}
function openChecklistScreenshot(id){
  currentChecklistScreenshotId = id;
  const input = document.getElementById('checklist-screenshot-file');
  if(input){ input.value=''; input.click(); }
}
function saveChecklistScreenshot(input){
  const file = input.files[0];
  if(!file || currentChecklistScreenshotId == null) return;
  const reader = new FileReader();
  reader.onload = e => {
    const item = checklists.find(c => c.id === currentChecklistScreenshotId);
    if(item){ item.screenshot = e.target.result; save(); renderChecklist(); }
    currentChecklistScreenshotId = null;
  };
  reader.readAsDataURL(file);
}
function removeChecklistScreenshot(id){
  const item = checklists.find(c => c.id === id);
  if(item){ delete item.screenshot; save(); renderChecklist(); }
}

