// ===== MATCHTRADER PARSER =====
function _isMatchTraderCSV(headers){
  const needed = ['status','side','symbol','opentime','closetime','openprice','closeprice','profit'];
  return needed.filter(h=>headers.some(x=>x.includes(h))).length >= 6;
}

function _parseMatchTraderCSV(lines, sep, input){
  const headers = lines[0].split(sep).map(h=>h.replace(/"/g,'').trim().toLowerCase());
  const maxId = trades.length ? Math.max(...trades.map(t=>t.id||0)) : 0;
  let nextId = maxId + 1;
  let imported = 0;

  const findIdx = (keywords) => headers.findIndex(h => keywords.some(k => h.includes(k)));
  const statusIdx = findIdx(['status']);
  const sideIdx = findIdx(['side','direction']);
  const symbolIdx = findIdx(['symbol','instrument']);
  const openTimeIdx = findIdx(['opentime','open','entry time']);
  const closeTimeIdx = findIdx(['closetime','close','exit time']);
  const openPriceIdx = findIdx(['openprice','open price','entry price']);
  const closePriceIdx = findIdx(['closeprice','close price','exit price']);
  const profitIdx = findIdx(['profit','pnl','pl']);

  for(let i=1;i<lines.length;i++){
    const cols = lines[i].split(sep).map(c=>c.replace(/"/g,'').trim());
    if(cols.length < 5) continue;

    const status = (cols[statusIdx]||'').toLowerCase();
    if(!status.includes('closed') && !status.includes('filled')) continue;

    const symbol = cols[symbolIdx]||'';
    if(!symbol) continue;

    const openTime = cols[openTimeIdx]||'';
    const closeTime = cols[closeTimeIdx]||'';
    if(!openTime) continue;

    const side = (cols[sideIdx]||'').toLowerCase();
    const dir = side.includes('buy') || side==='b' || side==='0' ? 'Buy' : 'Sell';
    
    const openPrice = parseFloat(cols[openPriceIdx])||0;
    const closePrice = parseFloat(cols[closePriceIdx])||0;
    let profit = parseFloat((cols[profitIdx]||'').replace(/[^\d.-]/g,''))||0;

    // Parse date
    let date = '';
    const dtMatch = openTime.match(/(\d{4})-(\d{1,2})-(\d{1,2})|(\d{1,2})[\/\-](\d{1,2})[\/\-](\d{4})|(\d{1,2})[\/\-](\d{1,2})[\/\-](\d{2,4})/);
    if(dtMatch){
      if(dtMatch[1]) date = `${dtMatch[1]}-${dtMatch[2].padStart(2,'0')}-${dtMatch[3].padStart(2,'0')}`;
      else if(dtMatch[4]) date = `${dtMatch[6]}-${dtMatch[4].padStart(2,'0')}-${dtMatch[5].padStart(2,'0')}`;
      else date = normalizeDate(`${dtMatch[7]}/${dtMatch[8]}/${dtMatch[9]}`);
    }
    if(!date) continue;

    let time = '';
    const timeMatch = openTime.match(/(\d{1,2}):(\d{2})(?::(\d{2}))?/);
    if(timeMatch) time = `${timeMatch[1].padStart(2,'0')}:${timeMatch[2]}${timeMatch[3]?':'+timeMatch[3].padStart(2,'0'):''}`;

    const dup = trades.find(t=>t.asset===symbol && t.date===date && Math.abs(parseFloat(t.pnl)-profit)<0.01);
    if(dup) continue;

    trades.push({
      id:nextId++, date, time,
      asset:symbol, market:_guessMarket(symbol), session:_guessSession(date+' '+time),
      dir, entry:String(openPrice), exit:String(closePrice),
      sl:'', tp:'', risk:String(Math.abs(profit)), rr:'',
      pnl:String(profit.toFixed(2)), result:profit>0?'Win':profit<0?'Loss':'BE',
      quality:'', strategy:'#MatchTrader', sessionTag:'',
      setup:'Imported from MatchTrader',
      entryReason:'', exitReason:'', emotion:'', mistakes:'', lessons:'',
      _imported:true
    });
    imported++;
  }

  save(); renderDashboard(); renderCalendar(); renderJournal();
  if(input) input.value='';
  _showToast(imported>0?`✅ ${imported} trades imported from MatchTrader`:'⚠ No trades found in MatchTrader file', imported>0?'#00f2ff':'#ffd700');
}


// ===== TV BALANCE HISTORY PARSER =====
function _isTVBalanceHistory(text){
  return text.includes('Close short position for symbol') || text.includes('Close long position for symbol');
}

function _parseTVBalanceHistory(text, input){
  let imported = 0;
  const maxId = trades.length ? Math.max(...trades.map(t=>t.id||0)) : 0;
  let nextId = maxId + 1;

  const lines = text.split('\n').map(l => l.trim()).filter(l => l.length > 0);
  
  // Process every 4 lines as one trade
  for(let i = 0; i < lines.length - 3; i += 4){
    try {
      const line1 = lines[i];      // datetime + balances
      const line2 = lines[i+1];    // PnL
      const line3 = lines[i+2];    // Currency (USD)
      const line4 = lines[i+3];    // Trade description
      
      // Skip if line4 doesn't contain "Close" keyword
      if(!line4.match(/close\s+(long|short)/i)) continue;
      
      // Extract datetime from line 1
      const dateMatch = line1.match(/^(\d{4}-\d{2}-\d{2})\s+(\d{2}:\d{2}:\d{2})/);
      if(!dateMatch) continue;
      const date = dateMatch[1];
      const time = dateMatch[2];
      
      // Extract PnL from line 2 (handle −, -, +, commas)
      let pnlStr = line2.replace(/[−–]/g,'-').replace(/,/g,'').trim();
      const pnl = parseFloat(pnlStr) || 0;
      
      // Extract direction from line 4
      const dirMatch = line4.match(/close\s+(long|short)/i);
      const direction = dirMatch ? dirMatch[1].toLowerCase() : null;
      if(!direction) continue;
      
      // Extract symbol from line 4
      const symMatch = line4.match(/for\s+symbol\s+([\w:.!_-]+)/i);
      let symbol = symMatch ? symMatch[1] : null;
      if(!symbol) continue;
      // Clean broker prefix
      symbol = symbol.replace(/^[A-Z0-9_]+:/,'');
      
      // Extract exit price from line 4
      const exitMatch = line4.match(/at\s+price\s+([\d.]+)/);
      const exitPrice = exitMatch ? parseFloat(exitMatch[1]) : 0;
      
      // Extract entry price (AVG Price) from line 4
      const entryMatch = line4.match(/Position\s+AVG\s+Price\s+was\s+([\d.]+)/i);
      const entryPrice = entryMatch ? parseFloat(entryMatch[1]) : 0;
      
      const dir = direction === 'long' ? 'Buy' : 'Sell';
      const result = pnl > 0 ? 'Win' : pnl < 0 ? 'Loss' : 'BE';
      const market = _guessMarket(symbol);
      const session = _guessSession(date + ' ' + time);
      
      // Check for duplicates
      const dup = trades.find(t => t.asset === symbol && t.date === date && Math.abs(parseFloat(t.pnl) - pnl) < 0.01);
      if(dup) continue;
      
      trades.push({
        id: nextId++, date, time,
        asset: symbol, market: market, session: session,
        dir, entry: String(entryPrice), exit: String(exitPrice),
        sl:'', tp:'', risk:'', rr:'',
        pnl: String(pnl), result,
        quality:'', strategy:'#Broker', sessionTag:'',
        setup:'Imported from Broker Statement',
        entryReason:'', exitReason:'', emotion:'', mistakes:'', lessons:'',
        _imported: true
      });
      imported++;
    } catch(e) {
      // Skip malformed trades
      continue;
    }
  }

  save();
  renderDashboard();
  renderCalendar();
  renderJournal();
  if(input) input.value = '';
  _showToast(imported > 0 ? `✅ ${imported} trade${imported>1?'s':''} imported successfully` : '⚠ No trades found — check format', imported > 0 ? '#00f2ff' : '#ffd700');
}

function _parseAndImport(text, input){
  const lines = text.split('\n').map(l=>l.trim()).filter(l=>l);
  if(!lines.length){ tvAlert('File empty!','warn'); return; }

  const sep = lines[0].includes('\t') ? '\t' : ',';
  const headers = lines[0].split(sep).map(h=>h.replace(/"/g,'').trim().toLowerCase());

  // Auto-detect KML/Tradovate Performance CSV
  if(_isKMLCSV(headers)){
    return _parseKMLCSV(lines, sep, input);
  }

  // Auto-detect TradingView CSV with headers
  if(_isTradingViewCSV(headers)){
    return _parseTradingViewCSV(lines, sep, input);
  }

  // Auto-detect TradingView multi-line paste (no headers, each order = multiple lines)
  if(_isTVMultiline(text)){
    return _parseTVMultiline(text, input);
  }

  let imported = 0;
  const maxId = trades.length ? Math.max(...trades.map(t=>t.id||0)) : 0;
  let nextId = maxId + 1;

  for(let i=1;i<lines.length;i++){
    const cols = lines[i].split(sep).map(c=>c.replace(/"/g,'').trim());
    if(cols.length < 3) continue;

    const row = {};
    headers.forEach((h,idx)=>{ row[h]=cols[idx]||''; });

    const type = (row['type']||row['direction']||'').toLowerCase();
    const symbol = row['symbol']||row['asset']||'';
    if(!symbol || type==='balance' || type==='deposit' || type==='credit') continue;

    const entry = (row['entry']||'').toLowerCase();
    if(entry==='in') continue;

    const profit = parseFloat(row['profit']||0);
    const volume = parseFloat(row['volume']||row['lots']||0);
    const price  = parseFloat(row['price']||row['open price']||0);
    const timeRaw = row['time']||row['date']||'';
    const datePart = timeRaw.split(' ')[0]||'';

    let result = 'BE';
    if(profit > 0) result = 'Win';
    else if(profit < 0) result = 'Loss';

    const dup = trades.find(t=>t.asset===symbol && t.date===datePart && parseFloat(t.pnl)===profit);
    if(dup) continue;

    trades.push({
      id: nextId++,
      date: datePart,
      time: timeRaw.split(' ')[1]||'',
      asset: symbol,
      market: 'Forex',
      session: 'London',
      dir: (type==='buy'||type==='0') ? 'Buy' : 'Sell',
      entry: String(price),
      exit: '',
      sl: '',
      tp: '',
      risk: '',
      rr: '',
      pnl: String(profit),
      result: result,
      quality: '',
      strategy: '#MT5',
      sessionTag: '',
      setup: 'Imported from MT5',
      entryReason: '',
      exitReason: '',
      emotion: '',
      mistakes: '',
      lessons: '',
      _imported: true
    });
    imported++;
  }

  save();
  renderDashboard();
  renderCalendar();
  renderJournal();
  input.value='';

  const toast = document.createElement('div');
  toast.textContent = imported > 0 ? `✅ ${imported} trades imported from MT5` : '⚠ No trades found — check file format';
  toast.style.cssText='position:fixed;bottom:24px;right:24px;background:'+(imported>0?'#00f2ff':'#ffd700')+';color:#000;padding:12px 20px;border-radius:10px;font-weight:600;font-size:14px;z-index:9999;font-family:var(--font-mono)';
  document.body.appendChild(toast);
  setTimeout(()=>toast.remove(), 3500);
}

