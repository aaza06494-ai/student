function renderRefTable(){
  const d=LOT_DATA[currentRefType];
  const cols=d.refRows[0].contracts;
  let h=`<table class="ref-table"><thead><tr><th>Pips</th>${cols.map(c=>`<th>${c} lot${c>1?'s':''}</th>`).join('')}</tr></thead><tbody>`;
