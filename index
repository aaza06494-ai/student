          </div>
        </div>
        ${c.screenshot?`<div class="checklist-screenshot-row"><img src="${escapeHTML(c.screenshot)}" alt="Checklist screenshot" onclick="event.stopPropagation();openChecklistScreenshot(${c.id})"/></div>`:''}`).join('')}
