// Toggle multi-select options for daily plan
function dpMultiSelect(el, key, val){
  el.classList.toggle('selected');
  if(!dpMultiAnswers[key]) dpMultiAnswers[key]=[];
  if(el.classList.contains('selected')){
    if(!dpMultiAnswers[key].includes(val)) dpMultiAnswers[key].push(val);
  } else {
    dpMultiAnswers[key] = dpMultiAnswers[key].filter(v=>v!==val);
  }
}

// Build and render the daily plan template from selected answers
function generateDailyTemplate(){
  const a = dpAnswers;
  const m = dpMultiAnswers;
  const confs = m.ny_conf || [];
  const confScore = confs.length;

  // --- Determine setup type ---
  let setupType = 'NO_TRADE';
  let setupLabel = '❌ No Trade Today';
  let setupClass = 'dp-badge-no';
  let direction = null;
  let reasons = [];
  let warnings = [];
  let rulesOut = [];

  // Hard stops
  if(a.news_conflict === 'yes'){
    rulesOut.push('🚨 High impact news conflicts with session — DO NOT TRADE');
  }
  if(a.htf_daily === 'ranging' && a.htf_1h === 'unclear'){
    rulesOut.push('⚠️ HTF ranging on both Daily & 1H — no clear bias');
  }
  if(a.ldn_dir === 'choppy'){
    warnings.push('London was choppy — wait for NY to give clear direction before entering');
  }

  // Logic to determine template
  const htfBullish = a.htf_daily === 'bullish';
  const htfBearish = a.htf_daily === 'bearish';
  const londonBullish = a.ldn_dir === 'bullish';
  const londonBearish = a.ldn_dir === 'bearish';
  const londonSweptReversed = a.ldn_sweep === 'yes_reversed';
  const londonReachedHTF = a.ldn_hft === 'yes' || a.ldn_hft === 'partial';
  const londonAligned = a.ldn_htf === 'yes';

  if(rulesOut.length === 0){
    // NY REVERSE: London went one way, HTF says other, or London swept and reversed
    if(londonSweptReversed && htfBullish && londonBearish){
      setupType = 'NY_REVERSE';
      setupLabel = '🔄 NY Reverse — BUY';
      setupClass = 'dp-badge-buy';
      direction = 'BUY';
      reasons.push('London swept sell-side and reversed → NY continuation to upside');
      reasons.push('HTF Daily is bullish — London was a manipulation sweep');
    } else if(londonSweptReversed && htfBearish && londonBullish){
      setupType = 'NY_REVERSE';
      setupLabel = '🔄 NY Reverse — SELL';
      setupClass = 'dp-badge-sell';
      direction = 'SELL';
      reasons.push('London swept buy-side and reversed → NY continuation to downside');
      reasons.push('HTF Daily is bearish — London was a manipulation sweep');
    }
