async function handleReportUpload(files){
  if(!files?.length) return;
  const file = files[0];
  const name = file.name || '';
  const ext = name.split('.').pop().toLowerCase();
  const allowed = ['pdf','docx','doc'];
  if(!allowed.includes(ext)){
    tvAlert('Only PDF and DOCX uploads are allowed.','warn');return;
  }
  const reader = new FileReader();
  reader.onload = async function(e){
    const dataUrl = e.target.result;
    await submitReportFile(file, dataUrl);
  };
  reader.readAsDataURL(file);
}
async function submitReportFile(file, dataUrl){
  const name = currentUser || 'Student';
  const type = file.name.match(/\.pdf$/i) ? 'pdf' : 'docx';
  const payload = {
    type: 'report',
    name,
    student_name: name,
    fileName: file.name,
    fileType: file.type || (type==='pdf' ? 'application/pdf' : 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'),
    fileData: dataUrl,
    uploadedAt: new Date().toISOString(),
    reportSubmitted: true,
  };
  try{
    const {data, error} = await supabaseClient.from('exports').insert([{ student_name: name, username: name, payload }]).select();
    if(error) throw error;
    tvAlert('Report submitted to Admin.');
  }catch(err){
    tvAlert('Report submission failed: '+(err.message||err),'error');
  }
}
