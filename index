  const accountId = currentAccount.id;
  try{
    const { data, error } = await supabaseClient.from('trades').select('*').eq('account_id', accountId).order('created_at', { ascending:true });
    if(error) throw error;
    const remoteTrades = (data||[]).map(t=>normalizeTrade({
      id: t.id,
      date: t.date,
      time: t.time,
      asset: t.asset,
      market: t.market,
      dir: t.direction || t.dir,
      entry: t.entry,
      exit: t.exit,
      pnl: t.pnl,
      sl: t.sl,
      tp: t.tp,
      result: t.result,
      quality: t.quality,
      strategy: t.strategy,
      sessionTag: t.sessionTag,
      notes: t.notes,
      created_at: t.created_at,
      updated_at: t.updated_at
    }));
    trades = mergeRemoteWithLocalTrades(accountId, remoteTrades);
    saveLocalTrades(accountId);
    clearLocalDeletedTradeIds(accountId);
  }catch(e){
    console.warn('Could not load trades from Supabase', e);
    trades = loadLocalTrades(accountId);
  }
  try{
    if(currentAccount.checklists && Array.isArray(currentAccount.checklists)){
      checklists = currentAccount.checklists;
      saveLocalChecks(accountId);
    } else {
      checklists = loadLocalChecks(accountId);
      if(!Array.isArray(checklists) || !checklists.length) checklists = defaultChecklists();
    }
  }catch(e){
    checklists = defaultChecklists();
  }
}

