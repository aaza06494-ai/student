// Compute summary statistics from trades array
function calcStats(){
  const pnls = trades.map(t=>parseFloat(t.pnl)||0);
  const wins = trades.filter(t=>t.result==='Win');
  const losses = trades.filter(t=>t.result==='Loss');
  const totalPnl = pnls.reduce((a,b)=>a+b,0);
  const winRate = trades.length ? (wins.length/trades.length*100) : 0;
  const avgWin = wins.length ? wins.reduce((a,t)=>a+(parseFloat(t.pnl)||0),0)/wins.length : 0;
  const avgLoss = losses.length ? losses.reduce((a,t)=>a+(parseFloat(t.pnl)||0),0)/losses.length : 0;
  const bestTrade = trades.length ? Math.max(...pnls) : 0;
  const worstTrade = trades.length ? Math.min(...pnls) : 0;
  const grossWin = wins.reduce((a,t)=>a+(parseFloat(t.pnl)||0),0);
  const grossLoss = Math.abs(losses.reduce((a,t)=>a+(parseFloat(t.pnl)||0),0));
  const profitFactor = grossLoss ? grossWin/grossLoss : grossWin>0?999:0;
  const avgRR = trades.filter(t=>t.rr).reduce((a,t,_,arr)=>a+(parseFloat(t.rr)||0)/arr.length,0);
  const expectancy = trades.length ? totalPnl/trades.length : 0;
  // consecutive win/loss counts
  let maxConsWins=0,maxConsLosses=0,cw=0,cl=0;
  trades.forEach(t=>{
    if(t.result==='Win'){cw++;cl=0;maxConsWins=Math.max(maxConsWins,cw);} 
    else if(t.result==='Loss'){cl++;cw=0;maxConsLosses=Math.max(maxConsLosses,cl);} 
    else{cw=0;cl=0;}
  });
  // peak-to-trough drawdown calculation
  let peak=0,maxDD=0,running=0;
  pnls.forEach(p=>{running+=p;if(running>peak)peak=running;maxDD=Math.max(maxDD,peak-running);});
  return {totalPnl,winRate,avgWin,avgLoss,bestTrade,worstTrade,profitFactor,avgRR,expectancy,maxConsWins,maxConsLosses,maxDD,grossWin,grossLoss,totalTrades:trades.length,wins:wins.length,losses:losses.length};
}

